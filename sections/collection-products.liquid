<section class="content-area">
  <div class="container-fluid">
    {% if section.settings.heading != blank %}
      <h2 class="h3 section-heading mb-0">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="row">
      {% if section.settings.collection != blank %}
        {% assign current_collection = section.settings.collection %}
      {% else %}
        {% assign current_collection = collection %}
      {% endif %}
      
      {% assign products = current_collection.products %}
      {% assign collection_name = current_collection.title | downcase %}

      {% if collection_name == 'samples' %}
        {% for product in products %}
          {% assign color_option = '' %}
          {% assign color_count = 0 %}
          {% for option in product.options_with_values %}
            {% if option.name == 'Color' %}
              {% assign color_option = option %}
              {% assign color_count = option.values.size %}
            {% endif %}
          {% endfor %}

          <div class="col-md-4 col-sm-6">
            <div class="box style2">
              <div class="inner">

                {% assign sample_variant = '' %}
                {% for variant in product.variants %}
                  {% if variant.title contains 'Sample' or variant.title contains 'sample' %}
                    {% assign sample_variant = variant %}
                    {% break %}
                  {% endif %}
                {% endfor %}

                {% if sample_variant != '' %}
                  <div class="color-diff">
                    <span>Color:</span> 
                    <span class="color-name">{{ sample_variant.option1 }}</span>
                  </div>
                {% endif %}
                
                <div class="sample-box-slider" id="slider-{{ product.id }}">
                  {% assign seen_images = '' %}
                  {% for variant in product.variants %}
                    {% if variant.title contains 'Sample' or variant.title contains 'sample' %}
                      {% if variant.featured_image %}
                        {% unless seen_images contains variant.featured_image.src %}
                          <div class="slide"
                              data-variant-id="{{ variant.id }}"
                              data-variant-color="{{ variant.option1 | escape }}"
                              data-is-sample="true">
                            <img 
                              src="{{ variant.featured_image | img_url: '800x' }}" 
                              alt="{{ variant.title | escape }}">
                          </div>
                          {% assign seen_images = seen_images | append: variant.featured_image.src | append: ',' %}
                        {% endunless %}
                      {% endif %}
                    {% endif %}
                  {% endfor %}
                </div>

                {%- comment -%} Expose variant data to JS {%- endcomment -%}
                <script type="application/json" id="variant-data-{{ product.id }}">
                {
                  {% for variant in product.variants %}
                    {% assign is_sample = false %}
                    {% if variant.title contains 'Sample' or variant.title contains 'sample' %}
                      {% assign is_sample = true %}
                    {% endif %}
                    "{{ variant.id }}": {
                      "id": {{ variant.id }},
                      "title": "{{ variant.title | escape }}",
                      "color": "{{ variant.option1 | escape }}",
                      "is_sample": {{ is_sample }},
                      "image": "{{ variant.featured_image.src | default: product.featured_image.src }}",
                      "image_id": {{ variant.featured_image.id | default: 'null' }}
                    }{% unless forloop.last %},{% endunless %}
                  {% endfor %}
                }
                </script>
              </div>

              <div class="text">
                <h3 class="title">{{ product.title }}</h3>
                {% if color_count > 0 %}
                  <p>{{ color_count }} Color{% if color_count > 1 %}s{% endif %}</p>
                {% endif %}
                
                <a href="javascript:;" class="cta-btn btn_default order-sample-btn" data-variant-id="">
                  Order Sample
                </a>

                <a href="{{ product.url }}" class="cta-btn btn_default_border">
                  Product Details
                </a>
              </div>
            </div>
          </div>
        {% endfor %}
      
      {% else %}
        {% comment %}================ DEFAULT COLLECTION STRUCTURE ================ {% endcomment %}
        {% for product in products %}
          {% assign color_count = 0 %}
          {% for option in product.options_with_values %}
            {% if option.name == 'Color' %}
              {% assign color_count = option.values.size %}
            {% endif %}
          {% endfor %}
      
          <div class="col-sm-4">
            <a href="{{ product.url }}" class="box style2">
              <img src="{{ product.featured_image | img_url: 'master' }}" alt="{{ product.title | escape }}">
              <div class="text">
                <h3 class="title">{{ product.title }}</h3>
                {% if color_count > 0 %}
                  <p>{{ color_count }} Color{% if color_count > 1 %}s{% endif %}</p>
                {% endif %}
              </div>
            </a>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.sample-box-slider').forEach(sliderEl => {
    const $slider = $(sliderEl);
    const box = sliderEl.closest('.box');
    const orderBtn = box.querySelector('.cta-btn.btn_default');
    const detailsBtn = box.querySelector('.cta-btn.btn_default_border');
    const colorDiff = box.querySelector('.color-diff span:last-child');

    function ensureCartContainer() {
      let cartContainer = document.querySelector('cart-container');
      if (!cartContainer) {
        cartContainer = document.createElement('cart-container');
        document.body.appendChild(cartContainer);
      }
      return cartContainer;
    }

    function ensureCartBadge() {
      const headerCart = document.querySelector('.shipment, .header-cart, .site-header__cart') || document.body;
      let badge = headerCart.querySelector('.cart-count-badge');
      if (!badge) {
        badge = document.createElement('span');
        badge.className = 'cart-count-badge';
        badge.textContent = '0';
        headerCart.appendChild(badge);
      }
      return badge;
    }

    function refreshBadge() {
      const badge = ensureCartBadge();
      fetch('/cart.js')
        .then(res => res.json())
        .then(cart => {
          badge.textContent = cart.item_count || 0;
        });
    }

    function updateFromCurrentSlide() {
      const currentSlide = sliderEl.querySelector('.slick-current');
      if (!currentSlide) return;
      const variantId = currentSlide.dataset.variantId;
      const color = currentSlide.dataset.variantColor;

      if (orderBtn) {
        orderBtn.dataset.variantId = variantId || '';
        orderBtn.classList.toggle('disabled', !variantId);
      }

      if (detailsBtn && variantId) {
        const baseUrl = detailsBtn.href.split('?')[0];
        detailsBtn.href = `${baseUrl}?variant=${variantId}`;
      }

      if (colorDiff && color) colorDiff.textContent = color;
    }

    $slider.on('init afterChange', updateFromCurrentSlide);

    // --- Add to Cart with theme's cart-container (auto drawer refresh)
    if (orderBtn) {
      orderBtn.addEventListener('click', async function(e) {
        e.preventDefault();
        const variantId = this.dataset.variantId;
        if (!variantId) {
          alert('Please select a sample variant.');
          return;
        }

        const formData = new FormData();
        formData.append('id', variantId);
        formData.append('quantity', 1);

        const cartContainer = ensureCartContainer();

        try {
          // use the theme's built-in cart handler
          await cartContainer.add(formData);

          // trigger your global event (cart updates, etc.)
          window.dispatchEvent(new Event('kt.cart.reloaded'));

          // update badge manually
          refreshBadge();

          // open drawer (Bootstrap offcanvas or similar)
          const offcanvas = document.querySelector('#offcanvas-cart');
          if (offcanvas && window.bootstrap) {
            window.bootstrap.Offcanvas.getOrCreateInstance(offcanvas).show();
          }

          // temporary button feedback
          const btnText = this.textContent;
          this.textContent = 'Added!';
          this.classList.add('added');
          setTimeout(() => {
            this.textContent = btnText;
            this.classList.remove('added');
          }, 1500);

        } catch (err) {
          console.error('Cart add failed:', err);
          alert('Something went wrong adding to cart.');
        }
      });
    }
  });
});
</script>

{% schema %}
{
  "name": "Collection Products",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    }
  ],
  "presets": [
    {
      "name": "Collection Products"
    }
  ]
}
{% endschema %}