{% liquid
  assign variants_json = product.variants | json
%}

<!-- Content Start -->
<section class="product-single-banner" id="product-main{{ product.id }}" >
    <div class="container-fluid">
        <div class="cs-top-bar">
            <div class="row align-items-lg-center">
                <div class="col-lg-7">
                    <div class="top-actions  d-none d-lg-block">
                        <ul class="product-tools">
                          {% if product.metafields.custom.installation-guides != blank %}
                            <li>
                              <a href="{{ product.metafields.custom.installation-guides | file_url }}" download>
                                <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/download-dark.webp" alt="icon">
                                Installation Guide
                              </a>
                            </li>
                          {% else %}
                            <li>
                              <a href="https://creativemines-trade.myshopify.com/pages/resources">
                                <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/download-dark.webp" alt="icon">
                                Installation Guide
                              </a>
                            </li>
                          {% endif %}

                          {% if product.metafields.custom.hatch_pattern != blank %}
                            <li>
                              <a href="{{ product.metafields.custom.hatch_pattern | file_url }}" download>
                                <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/download-dark.webp" alt="icon">
                                Hatch Pattern
                              </a>
                            </li>
                          {% endif %}

                          <li>
                            <a href="javascript:;" class="download-image" data-img="{{ product.featured_image | img_url: 'master' }}">
                              <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/download-dark.webp" alt="icon">
                              Download Image
                            </a>
                          </li>

                          <li>
                            <a href="javascript:;" class="share-image" data-img="{{ product.featured_image | img_url: 'master' }}" data-title="{{ product.title }}">
                              <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/share.webp" alt="icon">
                              Share Image
                            </a>
                          </li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="ps-lg-5">
                        {% assign back_collection = product.collections.first %}
                        
                        {% if back_collection %}
                          <a class="back_btn" href="{{ back_collection.url }}">
                            <em class="fa-solid fa-angle-left"></em> {{ back_collection.title }} Collections
                          </a>
                        {% endif %}
                        
                        <h1 class="heading d-lg-none">{{ product.title }}</h1>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
          <!-- Product Gallery -->
          <div class="col-lg-7">

              <script id="variantVideos" type="application/json">
              {
                {% for variant in product.variants %}
                  "{{ variant.id }}": [
                    {% if variant.metafields.custom.video %}
                      {% for file in variant.metafields.custom.video.value %}
                        {% if file.media_type == "video" %}
                          {% assign mp4_source = file.sources | where: "format", "mp4" | first %}
                          {% if mp4_source %}
                            { "url": "https:{{ mp4_source.url }}" }{% unless forloop.last %},{% endunless %}
                          {% endif %}
                        {% endif %}
                      {% endfor %}
                    {% endif %}
                  ]{% unless forloop.last %},{% endunless %}
                {% endfor %}
              }
              </script>

              {% assign first_variant = product.selected_or_first_available_variant %}
              {% assign selected_color = first_variant.option1 %}

              {%- comment -%}
              Collect all videos from variants that share the same color.
              {%- endcomment -%}
              {% assign videos_html = '' %}

              {%- for v in product.variants -%}
                {% if v.option1 == selected_color and v.metafields.custom.video %}
                  {% for file in v.metafields.custom.video.value %}
                    {% if file.media_type == "video" %}
                      {% assign mp4_source = file.sources | where: "format", "mp4" | first %}
                      {% if mp4_source %}
                        {% capture videos_html %}
                          {{ videos_html }}
                          <div class="slide">
                            <div class="image-box">
                              <video autoplay playsinline muted loop>
                                <source src="{{ mp4_source.url | prepend: 'https:' }}" type="video/mp4">
                              </video>
                            </div>
                          </div>
                        {% endcapture %}
                      {% endif %}
                    {% endif %}
                  {% endfor %}
                {% endif %}
              {%- endfor -%}

              {%- comment -%}
              Slider wrapper — use your `.product-single-slider` class.
              {%- endcomment -%}
              <div class="product-single-slider-wrap">

              <div class="variant-featured-image">
                {% if first_variant.featured_image %}
                  <div class="image-box">
                    <img
                      src="{{ first_variant.featured_image | img_url: '1200x' }}"
                      alt="{{ first_variant.title | escape }}"
                    >
                  </div>
                {% endif %}
              </div>

              <!-- Only Videos inside Slider -->
              <div class="product-single-slider-div">
                <div class="product-single-slider">
                  {{ videos_html }}
                </div>
              </div>

              </div>

          </div>

          <!-- Product Info -->
          <div class="col-lg-5">
            <div class="ps-lg-5">
              <div class="product-single-info">
                <div class="d-none d-lg-block">
                  <h1 class="heading">{{ product.title }}</h1>
                  {% if product.metafields.custom.subtitle %}
                    <p class="product-subtitle">{{ product.metafields.custom.subtitle.value }}</p>
                  {% endif %}
                </div>

                <!-- Example Meta (replace with metafields if needed) -->
                <div class="pr-single-meta">
                  <p>Color: <span>{{ product.selected_or_first_available_variant.option1 }}</span></p>
                </div>

                <!-- Variant Images / Swatches -->
                {% if product.has_only_default_variant == false %}
                  <div class="custom-checkbox">
                    <ul>
                      {% for option in product.options_with_values %}
                        {% if option.name == "Color" %}
                          {% for value in option.values %}
                            {% assign variant = product.variants | where: "option1", value | first %}
                            <li>
                              <div class="cs-item">
                                <input type="radio"
                                      name="color"
                                      id="color-{{ forloop.index }}"
                                      value="{{ value }}"
                                      {% if variant == product.selected_or_first_available_variant %}checked{% endif %}>
                                <label for="color-{{ forloop.index }}">
                                  {% if variant.featured_image %}
                                    <img src="{{ variant.featured_image | img_url: '100x' }}" alt="{{ value }}">
                                  {% else %}
                                    {{ value }}
                                  {% endif %}
                                </label>
                              </div>
                            </li>
                          {% endfor %}
                        {% endif %}
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}

                <!-- Mobile Description -->
                <div class="mt-3 d-md-none">
                  <p>{{ product.description | strip_html | truncate: 180 }}</p>
                  <div class="top-actions">
                    <ul>
                        <li><a href="javascript:;"><img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/download-dark.webp" alt="icon">Installation Guide</a></li>
                        <li><a href="javascript:;"><img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/download-dark.webp" alt="icon">Hatch Pattern</a></li>
                        <li><a href="javascript:;"><img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/download-dark.webp" alt="icon">Download Image</a></li>
                        <li><a href="javascript:;"><img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/share.webp" alt="icon">Share Image</a></li>
                    </ul>
                  </div>
                </div>

                {% if customer %}
                    {% if customer.tags contains 'B2B Approved' or customer.tags contains 'B2B_Approved' %}

                    <!-- Materials Calculator -->
                    <div class="mt-calculator">
                      <span class="d-block title">Materials Calculator:</span>
                      <form>
                        <ul class="row g-2">
                          <li class="col-md-5 col-sm-4">
                            <label for="sf">Square Ft. Needed</label>
                            <div class="mt-fields">
                              <input id="sf" type="number" min="0" placeholder="200">
                              <span class="pos_label">SF</span>
                            </div>
                          </li>
                          <li class="col-md-5 col-sm-4">
                            <label for="lf">Linear Ft. Needed</label>
                            <div class="mt-fields">
                              <input id="lf" type="number" min="0" placeholder="24">
                              <span class="pos_label">LF</span>
                            </div>
                          </li>
                          <li class="col-md-2 col-sm-4">
                            <label for="overage">Overage</label>
                            <div class="mt-fields">
                              <select id="overage">
                                <option value="10">10%</option>
                                <option value="15">15%</option>
                                <option value="25">25%</option>
                                <option value="45">45%</option>
                                <option value="75">75%</option>
                              </select>
                            </div>
                          </li>
                        </ul>
                      </form>
                    </div>

                    <!-- Box Option -->
                    <div class="cl-action">
                      <div>
                        <input type="checkbox" id="cl1">
                        <label for="cl1">Ship Order in All Small Boxes</label>
                      </div>
                      <div class="box-dm">
                        <a href="#" id="showBoxInfo">View Box Dimensions</a>
                        <div id="boxInfo" class="small mt-2 text-start"></div>
                      </div>

                    </div>

                    <!-- Actions -->
                    <div class="cs-actions mt-0">
                      <div class="left">
                        <form method="post" action="/cart/add" id="sampleForm" class="product-form" data-product-form>
                          <input type="hidden" name="id" id="sampleVariantId" value="{{ product.selected_or_first_available_variant.id }}">
                          <button type="submit" class="cta-btn btn_default">Order Sample</button>
                          <a href="#" class="cta-btn btn_default_border" id="startProjectBtn">Add to Cart</a>
                        </form>
                      </div>
                      <div class="right text-end">
                        <span class="d-block subtotal">Subtotal: {{ cart.total_price | money }}</span>
                        <div id="boxInfo" class="small mt-2 text-start" style="display:none;"></div>
                      </div>
                    </div>

                    <!-- Product Variants JSON -->
                    <script id="productVariants" type="application/json">
                    [
                      {% for variant in product.variants %}
                        {
                          "id": {{ variant.id }},
                          "title": {{ variant.title | json }},
                          "price": {{ variant.price | json }},
                          "option1": {{ variant.option1 | json }},
                          "available": {{ variant.available | json }},
                          "metafields": {
                            "custom": {
                              {% if variant.title contains 'Flat' %}
                                "coverage": {{ variant.metafields.custom.coverage-square-feet | default: 0 }}
                              {% elsif variant.title contains 'Corner' %}
                                "coverage": {{ variant.metafields.custom.coverage-lineal-feet | default: 0 }}
                              {% else %}
                                "coverage": 0
                              {% endif %}
                            }
                          }
                        }{% unless forloop.last %},{% endunless %}
                      {% endfor %}
                    ]
                    </script>

                    <!-- Calculator Logic -->
                    <script>
                    document.addEventListener('DOMContentLoaded', function () {
                        const productVariants = JSON.parse(document.getElementById('productVariants').textContent);
                        const subtotalEl = document.querySelector('.subtotal');
                        const sfInput = document.getElementById('sf');
                        const lfInput = document.getElementById('lf');
                        const overSelect = document.getElementById('overage');
                        const allSmall = document.getElementById('cl1');
                        const boxInfo = document.getElementById('boxInfo');
                        const viewBoxBtn = document.getElementById('showBoxInfo');
                        const cartContainer = document.querySelector('cart-container');

                        if (!productVariants.length) return;

                        const formatMoney = cents => Shopify.formatMoney ? Shopify.formatMoney(cents) : '$' + (cents / 100).toFixed(2);

                        function calculateTotals() {
                          const A = parseFloat(sfInput.value) || 0; 
                          const B = parseFloat(lfInput.value) || 0; 
                          const P = parseFloat(overSelect.value) || 10;
                          const useSmallOnly = allSmall.checked;

                          const baseTitle = document.querySelector('.product__title')?.textContent?.trim() || '';
                          const variants = productVariants.filter(v => v.title.toLowerCase().includes('flat') || v.title.toLowerCase().includes('corner'));

                          const largeFlat = variants.find(v => v.title.toLowerCase().includes('large box') && v.title.toLowerCase().includes('flat'));
                          const smallFlat = variants.find(v => v.title.toLowerCase().includes('small box') && v.title.toLowerCase().includes('flat'));
                          const largeCorner = variants.find(v => v.title.toLowerCase().includes('large box') && v.title.toLowerCase().includes('corner'));
                          const smallCorner = variants.find(v => v.title.toLowerCase().includes('small box') && v.title.toLowerCase().includes('corner'));

                          if (!largeFlat || !smallFlat || !largeCorner || !smallCorner) return;

                          const Fb = parseFloat(largeFlat.metafields.custom.coverage || 0);
                          const Fs = parseFloat(smallFlat.metafields.custom.coverage || 0);
                          const Cb = parseFloat(largeCorner.metafields.custom.coverage || 0);
                          const Cs = parseFloat(smallCorner.metafields.custom.coverage || 0);

                          const totalFlat = A * (1 + P / 100);
                          const totalCorner = B * (1 + P / 100);

                          let flatLarge = 0, flatSmall = 0, cornerLarge = 0, cornerSmall = 0;

                          if (useSmallOnly) {
                            flatSmall = Math.ceil(totalFlat / Fs);
                            cornerSmall = Math.ceil(totalCorner / Cs);
                          } else {
                            flatLarge = Math.floor(totalFlat / Fb);
                            const remainFlat = totalFlat - flatLarge * Fb;
                            flatSmall = Math.ceil(remainFlat / Fs);

                            cornerLarge = Math.floor(totalCorner / Cb);
                            const remainCorner = totalCorner - cornerLarge * Cb;
                            cornerSmall = Math.ceil(remainCorner / Cs);
                          }

                          const subtotalCents =
                            flatLarge * (largeFlat.price || 0) +
                            flatSmall * (smallFlat.price || 0) +
                            cornerLarge * (largeCorner.price || 0) +
                            cornerSmall * (smallCorner.price || 0);

                          subtotalEl.innerHTML = `Subtotal: <b>${formatMoney(subtotalCents)}</b>`;

                          boxInfo.dataset.flatLarge = flatLarge;
                          boxInfo.dataset.flatSmall = flatSmall;
                          boxInfo.dataset.cornerLarge = cornerLarge;
                          boxInfo.dataset.cornerSmall = cornerSmall;
                          boxInfo.dataset.subtotal = formatMoney(subtotalCents);
                        }

                        viewBoxBtn.addEventListener('mouseenter', function () {
                          if (!boxInfo.dataset.subtotal) return;
                          boxInfo.classList.add('hover-active');
                          boxInfo.innerHTML = `
                            <div class="mt-2">
                              <strong>Box Breakdown:</strong><br>
                              Flat: ${boxInfo.dataset.flatLarge} large box & ${boxInfo.dataset.flatSmall} small box<br>
                              Corner: ${boxInfo.dataset.cornerLarge} large box & ${boxInfo.dataset.cornerSmall} small box<br>
                              <span class="d-block mt-2"><strong>Total:</strong> ${boxInfo.dataset.subtotal}</span>
                            </div>
                          `;
                        });

                        [sfInput, lfInput, overSelect, allSmall].forEach(el => el.addEventListener('input', calculateTotals));

                        document.addEventListener('change', function (e) {
                          if (e.target.matches('.custom-checkbox input[name="color"]')) {
                            sfInput.value = '';
                            lfInput.value = '';
                            overSelect.selectedIndex = 0;
                            allSmall.checked = false;

                            boxInfo.innerHTML = '';
                            subtotalEl.innerHTML = 'Subtotal: <b>$0.00</b>';

                            setTimeout(calculateTotals, 300);
                          }
                        });

                        calculateTotals();
                      });                
                    </script>

                    <!-- AJAX for BOTH -->
                    <script>
                      document.addEventListener('DOMContentLoaded', function () {
                        const productData = JSON.parse(document.getElementById('productVariants').textContent);
                        const sampleForm = document.getElementById('sampleForm');
                        const sampleInput = document.getElementById('sampleVariantId');
                        const startProjectBtn = document.getElementById('startProjectBtn');
                        const boxInfo = document.getElementById('boxInfo');

                        function getCartContainer() {
                          return document.querySelector('cart-container') || document.body.appendChild(document.createElement('cart-container'));
                        }

                        if (sampleForm) {
                          sampleForm.addEventListener('submit', async e => {
                            e.preventDefault();
                            const variantId = sampleInput.value;
                            if (!variantId) return;

                            const formData = new FormData();
                            formData.append('id', variantId);
                            formData.append('quantity', 1);

                            const cartContainer = getCartContainer();
                            await cartContainer.add(formData);
                          });
                        }

                        if (startProjectBtn) {
                          startProjectBtn.addEventListener('click', async e => {
                            e.preventDefault();

                            const flatLarge = parseInt(boxInfo.dataset.flatLarge || 0);
                            const flatSmall = parseInt(boxInfo.dataset.flatSmall || 0);
                            const cornerLarge = parseInt(boxInfo.dataset.cornerLarge || 0);
                            const cornerSmall = parseInt(boxInfo.dataset.cornerSmall || 0);

                            if (!flatLarge && !flatSmall && !cornerLarge && !cornerSmall) {
                              alert('Please enter your SF/LF values first.');
                              return;
                            }

                            function findVariant(type, shape) {
                              return productData.find(v => {
                                const t = v.title.toLowerCase();
                                return (
                                  t.includes(shape) &&
                                  (t.includes(type) ||
                                    (type === 'large box' && (t.includes('big') || t.includes('large'))) ||
                                    (type === 'small box' && t.includes('small')))
                                );
                              });
                            }

                            const largeFlat = findVariant('large box', 'flat');
                            const smallFlat = findVariant('small box', 'flat');
                            const largeCorner = findVariant('large box', 'corner');
                            const smallCorner = findVariant('small box', 'corner');

                            const items = [];
                            if (flatLarge > 0 && largeFlat) items.push({ id: largeFlat.id, quantity: flatLarge });
                            if (flatSmall > 0 && smallFlat) items.push({ id: smallFlat.id, quantity: flatSmall });
                            if (cornerLarge > 0 && largeCorner) items.push({ id: largeCorner.id, quantity: cornerLarge });
                            if (cornerSmall > 0 && smallCorner) items.push({ id: smallCorner.id, quantity: cornerSmall });

                            if (!items.length) {
                              alert('Could not match box variants.');
                              return;
                            }

                            const cartContainer = getCartContainer();

                            for (const item of items) {
                              const fd = new FormData();
                              fd.append('id', item.id);
                              fd.append('quantity', item.quantity);
                              const container = getCartContainer(); // reselect after each reload
                              await container.add(fd);
                            }

                            setTimeout(() => {
                              const offcanvas = document.querySelector('#offcanvas-cart');
                              if (offcanvas) {
                                window.bootstrap.Offcanvas.getOrCreateInstance(offcanvas).show();
                              }
                            }, 600);
                          });
                        }
                      });
                    </script>

                  {% endif %}
                {% else %}

                <div class="cs-actions">
                  <div class="left">
                      <form method="post" action="/cart/add" id="sampleForm" class="product-form" data-product-form>
                        <input type="hidden" name="id" id="sampleVariantId" value="{{ product.selected_or_first_available_variant.id }}">
                        <button type="submit" class="cta-btn btn_default">Order Sample</button>
                        <a href="#" class="cta-btn btn_default_border">Start a Project</a>
                      </form>

                      <script id="productVariants" type="application/json">
                        {{ product.variants | json }}
                      </script>
                  </div>
                  <div class="right text-md-end text-center">
                    <a href="javascript:;" 
                      class="share-product" 
                      data-title="{{ product.title }}" 
                      data-url="{{ shop.url }}{{ product.url }}">
                      <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/share.webp" alt="">
                      Share This Product
                    </a>
                  </div>

                  <!-- Share Popup -->
                  <div class="share-popup">
                    <div class="share-popup-inner">
                      <button class="close-share">&times;</button>
                      <h4>Share this product</h4>
                      <div class="share-icons">
                        <a href="#" class="share-fb" target="_blank" aria-label="Share on Facebook">
                          <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/facebook-dark.webp" alt="Facebook">
                        </a>
                        <a href="#" class="share-x" target="_blank" aria-label="Share on X">
                          <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/x-dark.webp" alt="X">
                        </a>
                        <a href="#" class="share-pin" target="_blank" aria-label="Share on Pinterest">
                          <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/pinterest-dark.webp" alt="Pinterest">
                        </a>
                        <a href="#" class="share-copy" aria-label="Copy link">
                          <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/link-dark.webp" alt="Copy Link">
                        </a>
                      </div>
                    </div>
                  </div>

                </div>
                {% endif %}                
              </div>
            </div>
          </div>
        </div>
    </div>
</section>

<section class="content-area pt-0">
  <div class="container-fluid">
    <div class="row">
      <div class="col-lg-7">
        <h2 class="h1">Experience the Difference</h2>
      </div>
      <div class="col-lg-5">
        <div class="cs-tab ps-lg-5">
          <ul id="myTab" role="tablist">
            <li class="nav-item" role="presentation">
              <button class="nav-link active" id="desc-tab" data-bs-toggle="tab" data-bs-target="#desc" type="button" role="tab" aria-controls="desc" aria-selected="true">
                Product Description
              </button>
            </li>

            {% if product.metafields.custom.technical-info != blank %}
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="specs-tab" data-bs-toggle="tab" data-bs-target="#specs" type="button" role="tab" aria-controls="specs" aria-selected="false">
                  Technical Specifications
                </button>
              </li>
            {% endif %}
          </ul>

          <div class="tab-content" id="myTabContent">
            <div class="tab-pane fade active show" id="desc" role="tabpanel" aria-labelledby="desc-tab">
              {{ product.description }}
            </div>

            {% if product.metafields.custom.technical-info != blank %}
              {% for page in product.metafields.custom.technical-info.value %}
                <div class="tab-pane fade" id="specs" role="tabpanel" aria-labelledby="specs-tab">
                  {{ page.content }}
                </div>
              {% endfor %}
            {% endif %}          
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const sampleForm = document.getElementById('sampleForm');
  const sampleInput = document.getElementById('sampleVariantId');
  const productData = JSON.parse(document.getElementById('productVariants').textContent);
  const variantRadios = document.querySelectorAll('.custom-checkbox input[name="color"]');

  if (!sampleForm || !sampleInput) return;

  // --- Ensure single clean cart badge ---
  function ensureCartBadge() {
    // Remove any duplicate or null text badges
    document.querySelectorAll('.cart-count-badge').forEach((badge, i) => {
      if (i > 0) badge.remove();
      else if (!badge.textContent || badge.textContent.includes('null') || badge.textContent.trim() === '') {
        badge.textContent = '0';
      }
    });

    // Get main shipment/cart element
    const headerCart = document.querySelector('.shipment, .header-cart, .site-header__cart') || document.body;

    // Find or create single badge
    let badge = headerCart.querySelector('.cart-count-badge');
    if (!badge) {
      badge = document.createElement('span');
      badge.className = 'cart-count-badge';
      badge.textContent = '0';
      headerCart.appendChild(badge);
    }

    // Always sanitize any rogue "null" text nodes in headerCart
    [...headerCart.childNodes].forEach(node => {
      if (node.nodeType === 3 && node.textContent.trim().toLowerCase().includes('null')) {
        node.remove();
      }
    });

    return badge;
  }

  // --- Update Sample Variant ---
  function updateSampleVariant(selectedVariant) {
    if (!selectedVariant) return;
    const sampleVariant = productData.find(v =>
      v.title.toLowerCase().includes('sample') &&
      v.option1 &&
      selectedVariant.option1 &&
      v.option1.trim().toLowerCase() === selectedVariant.option1.trim().toLowerCase()
    );

    sampleInput.value = sampleVariant ? sampleVariant.id : '';
    const button = sampleForm.querySelector('button[type="submit"]');
    button.disabled = !sampleVariant;
  }

  // --- Variant Switch ---
  variantRadios.forEach(radio => {
    radio.addEventListener('change', function() {
      const selectedValue = this.value.trim().toLowerCase();
      const selectedVariant = productData.find(v =>
        v.option1 && v.option1.trim().toLowerCase() === selectedValue
      );
      updateSampleVariant(selectedVariant);
    });
  });

  // --- Default Variant ---
  const defaultVariant = productData.find(v => v.id === {{ product.selected_or_first_available_variant.id }});
  updateSampleVariant(defaultVariant);

  // --- AJAX Add to Cart ---
  sampleForm.addEventListener('submit', async function(e) {
    e.preventDefault();
    const variantId = sampleInput.value;
    if (!variantId) return;

    const formData = new FormData();
    formData.append('id', variantId);
    formData.append('quantity', 1);

    ensureCartBadge();
    let cartContainer = document.querySelector('cart-container');
    if (!cartContainer) {
      cartContainer = document.createElement('cart-container');
      document.body.appendChild(cartContainer);
    }

    try {
      await cartContainer.add(formData);
      window.dispatchEvent(new Event('kt.cart.reloaded'));
    } catch (err) {
      console.error('Cart add failed:', err);
      setTimeout(() => {
        const retryContainer = document.querySelector('cart-container');
        if (retryContainer && retryContainer.add) retryContainer.add(formData);
      }, 400);
    }
  });

  // --- Keep Badge & Qty Synced ---
  window.addEventListener('kt.cart.reloaded', () => {
    const badge = ensureCartBadge();

    fetch('/cart.js')
      .then(res => res.json())
      .then(data => {
        badge.textContent = (data.item_count || 0).toString();
      })
      .catch(() => {
        badge.textContent = '0';
      });

    // Clean any leftover "null" text inside shipment link again
    const headerCart = document.querySelector('.shipment, .header-cart, .site-header__cart');
    if (headerCart) {
      [...headerCart.childNodes].forEach(node => {
        if (node.nodeType === 3 && node.textContent.trim().toLowerCase().includes('null')) {
          node.remove();
        }
      });
    }

    document.querySelectorAll('.btn-qty-minus, .btn-qty-plus').forEach(btn => {
      btn.addEventListener('click', function() {
        const input = this.parentElement.querySelector('input[type="number"]');
        if (!input) return;
        if (this.classList.contains('btn-qty-minus')) input.stepDown();
        else input.stepUp();
        input.dispatchEvent(new Event('change', { bubbles: true }));
      });
    });
  });
});

function refreshCartBadge() {
  let badge = document.querySelector('.cart-count-badge');
  const headerCart = document.querySelector('.header-cart, .site-header__cart') || document.querySelector('.shipment');

  if (!badge) {
    badge = document.createElement('span');
    badge.className = 'cart-count-badge';
    badge.textContent = '0';
    headerCart?.appendChild(badge);
  }

  fetch('/cart.js')
    .then(r => r.json())
    .then(cart => {
      const count = cart.item_count || 0;
      badge.textContent = count.toString();
    })
    .catch(() => {
      badge.textContent = '0';
    });
}

// Run once on load and whenever the cart reloads
document.addEventListener('DOMContentLoaded', refreshCartBadge);
window.addEventListener('kt.cart.reloaded', refreshCartBadge);

</script>

<script>

document.addEventListener('DOMContentLoaded', function() {
  const sliderDiv = document.querySelector('.product-single-slider-div');
  const featuredImage = document.querySelector('.variant-featured-image');

  if (!sliderDiv || !featuredImage) return;

  sliderDiv.addEventListener('mouseenter', () => {
    sliderDiv.classList.add('act');
  });

  featuredImage.addEventListener('mouseenter', () => {
    sliderDiv.classList.remove('act');
  });
});

document.addEventListener('DOMContentLoaded', function() {
  const galleryWrapper = document.querySelector('.product-single-slider');
  const imageContainer = document.querySelector('.variant-featured-image');
  const wrapperContainer = document.querySelector('.product-single-slider-wrap');
  const variantRadios = document.querySelectorAll('.custom-checkbox input[name="color"]');
  const swrapperContainer = document.querySelector('.product-single-slider-div');

  
  if (!galleryWrapper || !imageContainer || !variantRadios.length) return;

  const productData = {{ product | json }};
  const videoData = JSON.parse(document.getElementById('variantVideos').textContent);

  function initCustomArrows($slider) {
    if (!$slider.length) return;

    $('.custom-cursor').remove();

    const slideCount = $slider.find('.slide').length;
    if (slideCount <= 1) {
      return; 
    }

    const $cursor = $(`
      <div class="custom-cursor" style="display:none;position:fixed;pointer-events:none;z-index:99;">
        <svg class="arrow-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" width="50" height="50">
          <path class="arrow-left" d="M41.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l160 160c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L109.3 256 246.6 118.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-160 160z" fill="#1C2120"/>
          <path class="arrow-right" d="M278.6 233.4c12.5 12.5 12.5 32.8 0 45.3l-160 160c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L210.7 256 73.4 118.6c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l160 160z" fill="#1C2120"/>
        </svg>
      </div>
    `);

    $('body').append($cursor);

    let direction = 'right';

    function updateDirection(e) {
      const offset = $slider.offset();
      const x = e.pageX - offset.left;
      const sliderWidth = $slider.width();
      const newDirection = x < sliderWidth / 2 ? 'left' : 'right';

      $cursor.find('.arrow-left').removeClass('active');
      $cursor.find('.arrow-right').removeClass('active');

      if (newDirection === 'left') {
        $cursor.find('.arrow-left').addClass('active');
      } else {
        $cursor.find('.arrow-right').addClass('active');
      }

      direction = newDirection;

      $cursor.css({
        left: e.pageX - 35 + 'px',
        top: e.pageY - 35 + 'px'
      });
    }

    $slider.on('mouseenter', function(e) {
      $cursor.fadeIn(150);
      updateDirection(e);
    });

    $slider.on('mousemove', function(e) {
      updateDirection(e);
    });

    $slider.on('mouseleave', function() {
      $cursor.fadeOut(150);
    });

    $slider.on('click', function() {
      if (direction === 'right') $slider.slick('slickNext');
      else $slider.slick('slickPrev');
    });
  }

  function rebuildGallery(variant) {
    if (!variant) return;

    if (typeof $ !== 'undefined' && $(galleryWrapper).hasClass('slick-initialized')) {
      $(galleryWrapper).slick('unslick');
    }

    galleryWrapper.innerHTML = '';
    imageContainer.innerHTML = '';

    if (variant.featured_image) {
      imageContainer.innerHTML = `
        <div class="image-box">
          <img src="${variant.featured_image.src}" alt="${variant.title}" loading="lazy">
        </div>`;
    }

    const variantVideos = videoData[variant.id];
    let slidesHTML = '';

    if (variantVideos && variantVideos.length) {
      variantVideos.forEach(video => {
        slidesHTML += `
          <div class="slide">
            <div class="image-box">
              <video class="product-video" autoplay loop muted playsinline preload="auto">
                <source src="${video.url}" type="video/mp4">
              </video>
            </div>
          </div>`;
      });
    }

    if (!slidesHTML.trim()) {
      swrapperContainer.classList.add('d-none');
      wrapperContainer.classList.remove('vact');
      galleryWrapper.innerHTML = '';
    } else {
      swrapperContainer.classList.remove('d-none');
      wrapperContainer.classList.add('vact');
      galleryWrapper.innerHTML = slidesHTML;

      $(galleryWrapper)
        .on('init', function() {
          requestAnimationFrame(() => {
            const firstVideo = $(galleryWrapper).find('.slick-current video').get(0);
            if (firstVideo) {
              firstVideo.muted = true;
              firstVideo.play().catch(() => {
                setTimeout(() => firstVideo.play(), 500);
              });
            }
          });
        })
        .on('afterChange', function(event, slick, currentSlide) {
          $(galleryWrapper).find('video').each(function() {
            this.pause();
          });

          const activeVideo = $(galleryWrapper)
            .find('.slick-slide[data-slick-index="' + currentSlide + '"] video')
            .get(0);
          if (activeVideo) {
            activeVideo.muted = true;
            activeVideo.play().catch(() => {
              setTimeout(() => activeVideo.play(), 500);
            });
          }
        })
        .slick({
          dots: false,
          arrows: false,
          infinite: true,
          speed: 300,
          slidesToShow: 1,
          slidesToScroll: 1,
          adaptiveHeight: true
        });

      initCustomArrows($(galleryWrapper));
    }

    const colorText = document.querySelector('.pr-single-meta span');
    if (colorText) colorText.textContent = variant.option1;
  }

  variantRadios.forEach(radio => {
    radio.addEventListener('change', function() {
      const selectedValue = this.value.trim().toLowerCase();
      const variant = productData.variants.find(v =>
        v.option1 && v.option1.trim().toLowerCase() === selectedValue
      );
      rebuildGallery(variant);
    });
  });

  const defaultVariant = productData.variants.find(
    v => v.id === {{ product.selected_or_first_available_variant.id }}
  );
  rebuildGallery(defaultVariant);
});
</script>

<script>

  document.addEventListener('DOMContentLoaded', function () {
  document.querySelectorAll('.download-image').forEach(btn => {
    btn.addEventListener('click', e => {
      e.preventDefault();
      const url = btn.dataset.img;
      const fileName = url.split('/').pop().split('?')[0];
      const link = document.createElement('a');
      link.href = url;
      link.download = fileName;
      document.body.appendChild(link);
      link.click();
      link.remove();
    });
  });

  document.querySelectorAll('.share-image').forEach(btn => {
    btn.addEventListener('click', e => {
      e.preventDefault();
      const imageUrl = btn.dataset.img;
      const title = btn.dataset.title;
      if (navigator.share) {
        navigator.share({
          title: title,
          text: `Check out this product: ${title}`,
          url: imageUrl
        }).catch(err => console.log('Share canceled', err));
      } else {
        navigator.clipboard.writeText(imageUrl).then(() => {
          alert('Image link copied to clipboard!');
        });
      }
    });
  });
});

document.addEventListener('DOMContentLoaded', function () {
  const shareBtn = document.querySelector('.share-product');
  const popup = document.querySelector('.share-popup');
  const closeBtn = document.querySelector('.close-share');

  if (!shareBtn || !popup) return;

  const title = shareBtn.dataset.title || document.title;
  const url = shareBtn.dataset.url || window.location.href;

  const fb = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;
  const tw = `https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`;
  const pin = `https://pinterest.com/pin/create/button/?url=${encodeURIComponent(url)}&description=${encodeURIComponent(title)}`;

  const fbLink = popup.querySelector('.share-fb');
  const twLink = popup.querySelector('.share-x');
  const pinLink = popup.querySelector('.share-pin');
  const copyLink = popup.querySelector('.share-copy');

  fbLink.href = fb;
  twLink.href = tw;
  pinLink.href = pin;

  // Handle Share button click
  shareBtn.addEventListener('click', e => {
    e.preventDefault();

    if (navigator.share) {
      navigator.share({ title, url })
        .catch(err => console.log('Share canceled:', err));
    } else {
      popup.classList.add('active');
    }
  });

  // Close popup
  closeBtn.addEventListener('click', () => popup.classList.remove('active'));
  popup.addEventListener('click', e => {
    if (e.target === popup) popup.classList.remove('active');
  });

  // Copy link
  copyLink.addEventListener('click', e => {
    e.preventDefault();
    navigator.clipboard.writeText(url).then(() => {
      copyLink.classList.add('copied');
      copyLink.querySelector('img').style.opacity = '0.5';
      alert('Product link copied!');
    });
  });
});

</script>

