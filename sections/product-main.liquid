                        const flatSmallQty = parseInt(boxInfo.dataset.flatSmall || 0);
                        const cornerLargeQty = parseInt(boxInfo.dataset.cornerLarge || 0);
                        const cornerSmallQty = parseInt(boxInfo.dataset.cornerSmall || 0);

                        if (!flatLargeQty && !flatSmallQty && !cornerLargeQty && !cornerSmallQty) {
                          alert('Please enter your SF/LF values first.');
                          return;
                        }

                        const items = [];
                        if (flatLargeQty > 0 && flatLarge)
                          items.push({ id: flatLarge.id, quantity: flatLargeQty });

                        if (flatSmallQty > 0 && flatSmall)
                          items.push({ id: flatSmall.id, quantity: flatSmallQty });

                        if (cornerLargeQty > 0 && cornerLarge)
                          items.push({ id: cornerLarge.id, quantity: cornerLargeQty });

                        if (cornerSmallQty > 0 && cornerSmall)
                          items.push({ id: cornerSmall.id, quantity: cornerSmallQty });

                        if (!items.length) {
                          alert('Could not match box variants for this color.');
                          return;
                        }

                        const cartContainer = getCartContainer();

                        for (const item of items) {
                          const fd = new FormData();
                          fd.append('id', item.id);
                          fd.append('quantity', item.quantity);
                          await cartContainer.add(fd);
                          await updateCartBadge();
                        }

                        setTimeout(() => {
                          const offcanvas = document.querySelector('#offcanvas-cart');
                          if (offcanvas) {
                            bootstrap.Offcanvas.getOrCreateInstance(offcanvas).show();
                            keepRefreshingCartDrawer();
                          }
                        }, 300);
                      });
                    });
                    </script>

                    <script>
                      document.addEventListener('DOMContentLoaded', function () {
                      const productVariants = JSON.parse(
                        document.getElementById('productVariants')?.textContent || '[]'
                      );

                      const sfInput = document.getElementById('sf');
                      const lfInput = document.getElementById('lf');
                      const overageEl = document.getElementById('overage');
                      const boxInfo = document.getElementById('boxesInfo');
                      const pricesEl = document.getElementById('csPrices');
                      const cfg = window.boxesTypeConfig || {};

                      if (!productVariants.length || !pricesEl || !boxInfo) return;

                      const sfBlock = pricesEl.querySelector('.price-sf');
                      const lfBlock = pricesEl.querySelector('.price-lf');

                      const moneyRound = n => '$' + n.toFixed(2);
                      const moneyFloor = n => '$' + (Math.round(n * 100) / 100).toFixed(2);

                      const DISCOUNT_RATE = 0.15; 

                      function findVariant(type, size, color) {
                        return productVariants.find(v =>
                          v.title.toLowerCase().includes(type) &&
                          v.title.toLowerCase().includes(size) &&
                          v.option1?.toLowerCase() === color
                        );
                      }

                      function getCoverage(variant) {
                        return Number(variant?.metafields?.custom?.coverage || 0);
                      }

                      function updatePrices() {
                        pricesEl.style.display = 'none';
                        sfBlock.style.display = 'none';
                        lfBlock.style.display = 'none';

                        const sf = parseFloat(sfInput?.value) || 0;
                        const lf = parseFloat(lfInput?.value) || 0;

                        const fl = parseInt(boxInfo.dataset.flatLarge || 0);
                        const fs = parseInt(boxInfo.dataset.flatSmall || 0);
                        const cl = parseInt(boxInfo.dataset.cornerLarge || 0);
                        const cs = parseInt(boxInfo.dataset.cornerSmall || 0);

                        if ((sf <= 0 && lf <= 0) || (!fl && !fs && !cl && !cs)) return;

                        const currentVariantId =
                          document.getElementById('currentVariantId')?.value || null;

                        const selected =
                          productVariants.find(v => v.id == currentVariantId) || productVariants[0];

                        const color = selected?.option1?.toLowerCase() || '';

                        const flatLarge   = findVariant('flat', 'large box', color);
                        const flatSmall   = findVariant('flat', 'small box', color);
                        const cornerLarge = findVariant('corner', 'large box', color);
                        const cornerSmall = findVariant('corner', 'small box', color);

                        let sfShown = false;
                        let lfShown = false;

                        /* ---------- PRICE PER SQUARE FT ---------- */
                        if (sf > 0 && (fl || fs)) {
                          let tradeTotal = 0;
                          let msrpTotal = 0;
                          let coverageTotal = 0;

                          if (flatLarge && fl) {
                            tradeTotal += fl * flatLarge.price;
                            msrpTotal  += fl * (flatLarge.price / (1 - DISCOUNT_RATE));
                            coverageTotal += fl * getCoverage(flatLarge);
                          }

                          if (flatSmall && fs) {
                            tradeTotal += fs * flatSmall.price;
                            msrpTotal  += fs * (flatSmall.price / (1 - DISCOUNT_RATE));
                            coverageTotal += fs * getCoverage(flatSmall);
                          }

                          if (coverageTotal > 0) {
                            sfBlock.querySelector('del').textContent =
                              moneyRound((msrpTotal / coverageTotal) / 100);
                            sfBlock.querySelector('strong').textContent =
                              moneyFloor((tradeTotal / coverageTotal) / 100);
                            sfBlock.style.display = 'block';
                            sfShown = true;
                          }
                        }

                        /* ---------- PRICE PER LINEAR FT ---------- */
                        if (!cfg.noCorners && lf > 0 && (cl || cs)) {
                          let tradeTotal = 0;
                          let msrpTotal = 0;
                          let coverageTotal = 0;

                          if (cornerLarge && cl) {
                            tradeTotal += cl * cornerLarge.price;
                            msrpTotal  += cl * (cornerLarge.price / (1 - DISCOUNT_RATE));
                            coverageTotal += cl * getCoverage(cornerLarge);
                          }

                          if (cornerSmall && cs) {
                            tradeTotal += cs * cornerSmall.price;
                            msrpTotal  += cs * (cornerSmall.price / (1 - DISCOUNT_RATE));
                            coverageTotal += cs * getCoverage(cornerSmall);
                          }

                          if (coverageTotal > 0) {
                            lfBlock.querySelector('del').textContent =
                              moneyRound((msrpTotal / coverageTotal) / 100);
                            lfBlock.querySelector('strong').textContent =
                              moneyFloor((tradeTotal / coverageTotal) / 100);
                            lfBlock.style.display = 'block';
                            lfShown = true;
                          }
                        }

                        if (sfShown || lfShown) {
                          pricesEl.style.display = 'block';
                        }
                      }

                      ['input', 'change'].forEach(evt => {
                        document.addEventListener(evt, e => {
                          if (['sf', 'lf', 'overage'].includes(e.target.id)) {
                            updatePrices();
                          }
                        });
                      });

                      const observer = new MutationObserver(updatePrices);
                      observer.observe(boxInfo, { attributes: true });

                      updatePrices();
                    });
                    </script>                  

                  {% endif %}                   
                  
                  {% endif %}
                {% else %}

                <div class="cs-actions">
                  <div class="left">
                      <form method="post" action="/cart/add" id="sampleForm" class="product-form only-order-sample" data-product-form>
                        <input type="hidden" name="id" id="sampleVariantId" value="{{ product.selected_or_first_available_variant.id }}">
                        <button type="submit" class="cta-btn btn_default">Order Sample</button>
                        <a href="https://creativemines-trade.myshopify.com/pages/start-project" class="cta-btn btn_default_border">Start a Project</a>
                      </form>

                      <script id="productVariants" type="application/json">
                        {{ product.variants | json }}
                      </script>
                  </div>
                  <div class="right text-md-end text-center">
                    <a href="javascript:;" 
                      class="share-product" 
                      data-title="{{ product.title }}" 
                      data-url="{{ shop.url }}{{ product.url }}">
                      <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/share.webp" alt="">
                      Share This Product
                    </a>
                  </div>

                  <!-- Share Popup -->
                  <div class="share-popup">
                    <div class="share-popup-inner">
                      <button class="close-share">&times;</button>
                      <h4>Share this product</h4>
                      <div class="share-icons">
                        <a href="#" class="share-fb" target="_blank" aria-label="Share on Facebook">
                          <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/facebook-dark.webp" alt="Facebook">
                        </a>
                        <a href="#" class="share-x" target="_blank" aria-label="Share on X">
                          <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/x-dark.webp" alt="X">
                        </a>
                        <a href="#" class="share-pin" target="_blank" aria-label="Share on Pinterest">
