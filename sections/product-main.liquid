{% liquid
  assign variants_json = product.variants | json
%}

<!-- Content Start -->
<section class="product-single-banner" id="product-main{{ product.id }}" >
    <div class="container-fluid">
        <div class="cs-top-bar">
            <div class="row align-items-lg-center">
                <div class="col-lg-7">
                    <div class="top-actions  d-none d-lg-block">
                      
                        <ul class="product-tools">
                          {% assign guides = product.metafields.custom["installation-guides"].value %}

                         {% if guides != blank %}
                          {% if guides.size > 1 %}
                              <li class="guide-dropdown">
                                  <a href="javascript:;">
                                      <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/download-dark.webp" alt="icon">
                                      Installation Guides
                                  </a>
                                  <ul>
                                      {% for file in guides %}
                                          <li>
                                              <a href="{{ file.url }}" download>
                                                  {% if file.alt != blank %}
                                                      {{ file.alt }}
                                                  {% else %}
                                                      Download Guide {{ forloop.index }}
                                                  {% endif %}
                                              </a>
                                          </li>
                                      {% endfor %}
                                  </ul>
                              </li>

                            {% else %}
                              {% for file in guides %}
                                <li>
                                  <a href="{{ file.url }}" download>
                                    <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/download-dark.webp" alt="icon">
                                    Installation Guide
                                  </a>
                                </li>
                              {% endfor %}
                            {% endif %}
                          {% endif %}

                          {% if product.metafields.custom.hatch_pattern != blank %}
                            <li>
                              <a href="{{ product.metafields.custom.hatch_pattern | file_url }}" download>
                                <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/download-dark.webp" alt="icon">
                                Hatch Pattern
                              </a>
                            </li>
                          {% endif %}

                          <li>
                            <a href="javascript:;" class="download-image" data-img="{{ product.featured_image | img_url: 'master' }}">
                              <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/download-dark.webp" alt="icon">
                              Download Image
                            </a>
                          </li>

                          <li>
                            <a href="javascript:;" class="share-image" data-img="{{ product.featured_image | img_url: 'master' }}" data-title="{{ product.title }}">
                              <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/share.webp" alt="icon">
                              Share Image
                            </a>
                          </li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="ps-lg-5">
                        {% assign back_collection = product.collections.first %}
                        
                        {% if back_collection %}
                          <a class="back_btn" href="{{ back_collection.url }}">
                            <em class="fa-solid fa-angle-left"></em> {{ back_collection.title }} Collections
                          </a>
                        {% endif %}
                        
                        <h1 class="heading d-lg-none">{{ product.title }}</h1>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
          <!-- Product Gallery -->
          <div class="col-lg-7">

<script>
  window.variantTechnicalInfo = {
    {% for v in product.variants %}
      "{{ v.id }}":
      {% if v.metafields.custom.technical_info != blank %}
        {{ v.metafields.custom.technical_info | metafield_text | json }}
      {% else %}
        ""
      {% endif %}
      {% unless forloop.last %},{% endunless %}
    {% endfor %}
  };
</script>
            
              <script id="variantVideos" type="application/json">
              {
                {% for variant in product.variants %}
                  "{{ variant.id }}": [
                    {% if variant.metafields.custom.video %}
                      {% for file in variant.metafields.custom.video.value %}
                        {% if file.media_type == "video" %}
                          {% assign mp4_source = file.sources | where: "format", "mp4" | first %}
                          {% if mp4_source %}
                            { "url": "https:{{ mp4_source.url }}" }{% unless forloop.last %},{% endunless %}
                          {% endif %}
                        {% endif %}
                      {% endfor %}
                    {% endif %}
                  ]{% unless forloop.last %},{% endunless %}
                {% endfor %}
              }
              </script>

              {% assign first_variant = product.selected_or_first_available_variant %}
              {% assign selected_color = first_variant.option1 %}

              {%- comment -%}
              Collect all videos from variants that share the same color.
              {%- endcomment -%}
              {% assign videos_html = '' %}

              {%- for v in product.variants -%}
                {% if v.option1 == selected_color and v.metafields.custom.video %}
                  {% for file in v.metafields.custom.video.value %}
                    {% if file.media_type == "video" %}
                      {% assign mp4_source = file.sources | where: "format", "mp4" | first %}
                      {% if mp4_source %}
                        {% capture videos_html %}
                          {{ videos_html }}
                          <div class="slide">
                            <div class="image-box">
                              <video autoplay playsinline muted loop>
                                <source src="{{ mp4_source.url | prepend: 'https:' }}" type="video/mp4">
                              </video>
                            </div>
                          </div>
                        {% endcapture %}
                      {% endif %}
                    {% endif %}
                  {% endfor %}
                {% endif %}
              {%- endfor -%}

              {%- comment -%}
              Slider wrapper — use your `.product-single-slider` class.
              {%- endcomment -%}
              <div class="product-single-slider-wrap">

              <div class="variant-featured-image">
                {% if first_variant.featured_image %}
                  <div class="image-box">
                    <img
                      src="{{ first_variant.featured_image | img_url: '1200x' }}"
                      alt="{{ first_variant.title | escape }}"
                    >
                  </div>
                {% endif %}
              </div>

              <!-- Only Videos inside Slider -->
              <div class="product-single-slider-div">
                <div class="product-single-slider">
                  {{ videos_html }}
                </div>
              </div>

              </div>

          </div>

          <!-- Product Info -->
          <div class="col-lg-5">
            <div class="ps-lg-5">
              <div class="product-single-info">
                <div class="d-none d-lg-block">
                  <h1 class="heading">{{ product.title }}</h1>
                  {% if product.metafields.custom.subtitle %}
                    <p class="product-subtitle">{{ product.metafields.custom.subtitle.value }}</p>
                  {% endif %}
                </div>

                <!-- Example Meta (replace with metafields if needed) -->
                <div class="pr-single-meta">
                  <p>Color: <span>{{ product.selected_or_first_available_variant.option1 }}</span></p>
                </div>

                <!-- Variant Images / Swatches -->
                {% if product.has_only_default_variant == false %}
                  <div class="custom-checkbox">
                    <ul>
                      {% for option in product.options_with_values %}
                        {% if option.name == "Color" %}
                          {% for value in option.values %}

                            {%- assign matched_variant = nil -%}
                            {% for v in product.variants %}
                              {% if v.options contains value %}
                                {% assign matched_variant = v %}
                                {% break %}
                              {% endif %}
                            {% endfor %}

                            <li>
                              <div class="cs-item">
                                <input type="radio"
                                      name="color"
                                      id="color-{{ forloop.index }}"
                                      value="{{ value }}"
                                      {% if matched_variant == product.selected_or_first_available_variant %}checked{% endif %}>

                                <label for="color-{{ forloop.index }}">
                                  {% if matched_variant and matched_variant.featured_image %}
                                    <img src="{{ matched_variant.featured_image | img_url: '100x' }}" alt="{{ value }}">
                                  {% else %}
                                    {{ value }}
                                  {% endif %}
                                </label>
                              </div>
                            </li>

                          {% endfor %}
                        {% endif %}
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}
                <input type="hidden" id="currentVariantId" value="{{ product.selected_or_first_available_variant.id }}">

                <!-- Build Variant Description JSON (Rich Text → HTML) -->
                <script>
                  window.variantDescriptions = {
                    {% for v in product.variants %}
                      "{{ v.id }}": {{ v.metafields.custom.description | metafield_text | json }}{% unless forloop.last %},{% endunless %}
                    {% endfor %}
                  };
                </script>

                <!-- Build Variant ID → Option Value Map -->
                <script>
                  window.productVariants = [
                    {% for v in product.variants %}
                      {
                        id: {{ v.id }},
                        option1: "{{ v.option1 }}"
                      }{% unless forloop.last %},{% endunless %}
                    {% endfor %}
                  ];
                </script>

                <!-- Load + Switch Variant Description -->
                <script>
                  document.addEventListener("DOMContentLoaded", function () {

                    const descBox = document.getElementById("variant-description");
                    const variantIdInput = document.getElementById("currentVariantId");

                    // Display selected variant description
                    function loadDescription(id) {
                      if (window.variantDescriptions[id]) {
                        descBox.innerHTML = window.variantDescriptions[id];
                      }
                    }

                    // Load default (first selected) variant description
                    loadDescription(variantIdInput.value);

                    // Update on swatch change
                    document.querySelectorAll('.custom-checkbox input[name="color"]').forEach(function (radio) {
                      radio.addEventListener("change", function () {
                        const selectedValue = this.value;

                        const variant = window.productVariants.find(v => v.option1 === selectedValue);
                        if (!variant) return;

                        variantIdInput.value = variant.id;
                        loadDescription(variant.id);
                      });
                    });

                  });
                </script>
                <!-- Mobile Description -->
                <div class="mt-3 d-md-none">
                  <!--<p>{{ product.description | strip_html | truncate: 180 }}</p> -->

                  <div class="sp-collapse">
                    <span>Resources <svg width="12" height="7" viewBox="0 0 12 7" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M11.0469 5.62756L6.02188 0.603032C5.98927 0.570377 5.95054 0.544471 5.90791 0.526796C5.86528 0.50912 5.81959 0.500022 5.77344 0.500022C5.72729 0.500022 5.68159 0.50912 5.63896 0.526796C5.59634 0.544471 5.55761 0.570377 5.525 0.603032L0.5 5.62756" stroke="#1C2120" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    </span>
                    <div class="top-actions">
                      <ul>
                          <li><a href="javascript:;"><img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/download-dark.webp" alt="icon">Installation Guide</a></li>
                          <li><a href="javascript:;"><img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/download-dark.webp" alt="icon">Hatch Pattern</a></li>
                          <li><a href="javascript:;"><img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/download-dark.webp" alt="icon">Download Image</a></li>
                          <li><a href="javascript:;"><img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/share.webp" alt="icon">Share Image</a></li>
                      </ul>
                    </div>
                  </div>
                </div>

                {% if product.metafields.custom.disable_add_to_cart %}

                <div class="cs-actions">
                  <div class="left">
                      <form method="post" action="/cart/add" id="sampleForm" class="product-form only-order-sample" data-product-form>
                        <input type="hidden" name="id" id="sampleVariantId" value="{{ product.selected_or_first_available_variant.id }}">
                        <button type="submit" class="cta-btn btn_default">Order Sample</button>

                        {% if section.settings.custom_heading != blank %}
                          <a href="#contact-to-order" class="cta-btn btn_default_border">{{ section.settings.custom_heading }}</a>
                        {% endif %}
                      </form>

                      {% if section.settings.custom_liquid != blank %}
                        <div class="trigger-popup">
                            <div class="tp-inner">
                                <div class="tp-close">&times;</div>
                                {{ section.settings.custom_liquid }}
                            </div>
                        </div>                        
                      {% endif %}                    

                      <script id="productVariants" type="application/json">
                        {{ product.variants | json }}
                      </script>
                  </div>
                  <div class="right text-md-end text-center">
                    <a href="javascript:;" 
                      class="share-product" 
                      data-title="{{ product.title }}" 
                      data-url="{{ shop.url }}{{ product.url }}">
                      <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/share.webp" alt="">
                      Share This Product
                    </a>
                  </div>

                  <!-- Share Popup -->
                  <div class="share-popup">
                    <div class="share-popup-inner">
                      <button class="close-share">&times;</button>
                      <h4>Share this product</h4>
                      <div class="share-icons">
                        <a href="#" class="share-fb" target="_blank" aria-label="Share on Facebook">
                          <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/facebook-dark.webp" alt="Facebook">
                        </a>
                        <a href="#" class="share-x" target="_blank" aria-label="Share on X">
                          <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/x-dark.webp" alt="X">
                        </a>
                        <a href="#" class="share-pin" target="_blank" aria-label="Share on Pinterest">
                          <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/pinterest-dark.webp" alt="Pinterest">
                        </a>
                        <a href="#" class="share-copy" aria-label="Copy link">
                          <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/link-dark.webp" alt="Copy Link">
                        </a>
                      </div>
                    </div>
                  </div>

                </div> 
                               
                {% else %}

                {% if customer %}
                    {% if customer.tags contains 'B2B Approved' or customer.tags contains 'B2B_Approved' %}

                    <div class="cs-prices" id="csPrices">
                      <div class="price-item price-sf" style="display:none;">
                        <span class="d-block">Price Per Square Ft.</span>
                        <span class="d-block price"><del></del> <strong></strong></span>
                      </div>
                      <div class="price-item price-lf" style="display:none;">
                        <span class="d-block">Price Per Linear Ft.</span>
                        <span class="d-block price"><del></del> <strong></strong></span>
                      </div>
                    </div>

                    <!-- Materials Calculator -->
                     {% if product.handle == 'stone-split-modular-small'  %}
                    <div class='variants-url'>
                      <a class="cta-btn btn_default_border cta-btn-active" href="/products/stone-split-modular-small">
                        Split Modular 2.5"
                      </a>
                       <a class="cta-btn btn_default_border" href="/products/stone-split-modular-large">
                        Split Modular 5"
                      </a>
                    </div>
                  {% elsif product.handle == 'stone-split-modular-large' %}
                    <div class='variants-url'>
                      <a class="cta-btn btn_default_border " href="/products/stone-split-modular-small">
                        Split Modular 2.5"
                      </a>
                       <a class="cta-btn btn_default_border cta-btn-active" href="/products/stone-split-modular-large">
                        Split Modular 5"
                      </a>
                    </div>
                  {% else %}
                    {% assign ref = product.metafields.custom['variant-product'].value %}
                    {% if ref %}
                      <a style="margin-top:20px;" class="cta-btn btn_default_border" href="{{ ref.url }}">
                        {{ ref.title }}
                      </a>
                    {% endif %}
                  {% endif %}
                    <div class="mt-calculator">
                      <span class="d-block title">Materials Calculator:</span>
                      <form>
                        <ul class="row g-2">
                          <li class="col-md-5 col-sm-4">
                            <label for="sf">Square Ft. Needed</label>
                            <div class="mt-fields">
                              <input id="sf" type="number" min="0" placeholder="0">
                              <span class="pos_label">SF</span>
                            </div>
                          </li>
                          <li class="col-md-5 col-sm-4">
                            <label for="lf">Linear Ft. Needed</label>
                            <div class="mt-fields">
                              <input id="lf" type="number" min="0" placeholder="0">
                              <span class="pos_label">LF</span>
                            </div>
                          </li>
                          <li class="col-md-2 col-sm-4">
                            <label for="overage">Overage</label>
                            <div class="mt-fields">
                              <select id="overage">
                                <option value="0">0%</option>
                                <option value="10" selected>10%</option>                                
                                <option value="15">15%</option>
                                <option value="25">25%</option>
                                <option value="45">45%</option>
                                <option value="75">75%</option>
                              </select>
                            </div>
                          </li>
                        </ul>
                      </form>
                    </div>

                    <!-- Box Option -->
                    <div class="cl-action">
                      <div>
                        <input type="checkbox" id="cl1">
                        <label for="cl1">Ship Order in All Small Boxes</label>
                      </div>
                      <div class="box-dm">
                        <a href="#" id="showBoxInfo">View Box Dimensions</a>
                        <div id="boxInfo" class="small mt-2 text-start">
                            {% if section.settings.box_dimension_image != blank %}
                              <div class="box-dimension-img">
                                <img 
                                  src="{{ section.settings.box_dimension_image | img_url: 'master' }}" 
                                  alt="Box Dimension">
                              </div>
                            {% endif %}                          
                        </div>
                      </div>
                    </div>

                    <div id="boxesInfo"></div>

                    <!-- Actions -->
                    <div class="cs-actions mt-0">
                      <div class="left">
                        <form id="sampleForm" class="order-sample-b2b">
                          <a href="#" class="cta-btn btn_default" id="startProjectBtn">Add to Cart</a>

                          <input type="hidden" id="sampleVariantId" value="">
                          <button type="submit" class="cta-btn btn_default_border">Order Sample</button>
                        </form>
                      </div>
                      <div class="right text-end">
                        <span class="d-block subtotal">Subtotal: {{ cart.total_price | money }}</span>
                      </div>
                    </div>

                    <!-- Product Variants JSON -->
                    <script id="productVariants" type="application/json">
                    [
                      {% for variant in product.variants %}
                        {
                          "id": {{ variant.id }},
                          "title": {{ variant.title | json }},
                          "price": {{ variant.price | json }},
                          "option1": {{ variant.option1 | json }},
                          "available": {{ variant.available | json }},
                          "metafields": {
                            "custom": {
                              {% if variant.title contains 'Flat' %}
                                "coverage": {{ variant.metafields.custom.coverage-square-feet | default: 0 }}
                              {% elsif variant.title contains 'Corner' %}
                                "coverage": {{ variant.metafields.custom.coverage-lineal-feet | default: 0 }}
                              {% else %}
                                "coverage": 0
                              {% endif %}
                            }
                          }
                        }{% unless forloop.last %},{% endunless %}
                      {% endfor %}
                    ]
                    </script>

                    {% assign boxes_type = product.metafields.custom.boxes_type.value | default: '' %}

                    {% assign is_large_only = false %}
                    {% assign is_small_only = false %}
                    {% assign is_no_corners = false %}

                    {% if boxes_type contains 'Large Box Only' %}
                      {% assign is_large_only = true %}
                    {% endif %}

                    {% if boxes_type contains 'Small Box Only' %}
                      {% assign is_small_only = true %}
                    {% endif %}

                    {% if boxes_type contains 'No Corners' %}
                      {% assign is_no_corners = true %}
                    {% endif %}                    

                    {% assign box_types = product.metafields.custom.boxes_type.value %}
                    {% assign has_box_restrictions = false %}

                    {% if box_types != blank %}
                      {% assign has_box_restrictions = true %}
                    {% endif %}

                    {% if has_box_restrictions %}

                    <script>
                    window.boxesTypeConfig = {
                      largeOnly: {{ is_large_only | json }},
                      smallOnly: {{ is_small_only | json }},
                      noCorners: {{ is_no_corners | json }}
                    };
                    </script>             

                    <script>
                    document.addEventListener('DOMContentLoaded', function () {
                      const productVariants = JSON.parse(
                        document.getElementById('productVariants')?.textContent || '[]'
                      );

                      const subtotalEl = document.querySelector('.subtotal');
                      const sfInput = document.getElementById('sf');
                      const lfInput = document.getElementById('lf');
                      const overSelect = document.getElementById('overage');
                      const allSmall = document.getElementById('cl1');
                      const boxInfo = document.getElementById('boxesInfo');
                      const cfg = window.boxesTypeConfig || {};

                      if (!productVariants.length) return;

                      /* ---------- FIND FLAT / CORNER VARIANTS ---------- */

                      const flatVariants = productVariants.filter(v =>
                        v.title.toLowerCase().includes('flat')
                      );

                      const cornerVariants = productVariants.filter(v =>
                        v.title.toLowerCase().includes('corner')
                      );

                      const largeFlat = flatVariants.find(v =>
                        v.title.toLowerCase().includes('large box')
                      );

                      const smallFlat = flatVariants.find(v =>
                        v.title.toLowerCase().includes('small box')
                      );

                      const largeCorner = cornerVariants.find(v =>
                        v.title.toLowerCase().includes('large box')
                      );

                      const smallCorner = cornerVariants.find(v =>
                        v.title.toLowerCase().includes('small box')
                      );

                      const hasLargeFlat = !!largeFlat;
                      const hasSmallFlat = !!smallFlat;

                      /* ---------- HIDE "ALL SMALL BOXES" CHECKBOX ---------- */
                      if (
                        cfg.largeOnly ||
                        cfg.smallOnly ||
                        !hasLargeFlat ||
                        !hasSmallFlat
                      ) {
                        allSmall?.closest('div')?.remove();
                      }

                      /* ---------- NO CORNERS UI ---------- */
                      if (cfg.noCorners) {
                        lfInput.value = '';
                        lfInput.closest('li')?.classList.add('d-none');

                        const sfLi = sfInput.closest('li');
                        sfLi?.classList.remove('col-md-5', 'col-sm-4');
                        sfLi?.classList.add('col-md-7', 'col-sm-6');

                        const overLi = overSelect.closest('li');
                        overLi?.classList.remove('col-md-2', 'col-sm-4');
                        overLi?.classList.add('col-md-5', 'col-sm-6');
                      }

                      const formatMoney = cents =>
                        window.Shopify?.formatMoney
                          ? Shopify.formatMoney(cents)
                          : '$' + (cents / 100).toFixed(2);

                      function calculateTotals() {
                        const A = parseFloat(sfInput.value) || 0;
                        const B = cfg.noCorners ? 0 : (parseFloat(lfInput.value) || 0);
                        const P = Number(overSelect.value);

                        if (A === 0 && B === 0) {
                          boxInfo.style.display = 'none';
                          subtotalEl.innerHTML = 'Subtotal: <b>$0.00</b>';
                          return;
                        }

                        /* ---------- DETERMINE MODE ---------- */
                        let useSmallOnly = allSmall?.checked || false;

                        if (cfg.largeOnly || (!hasSmallFlat && hasLargeFlat)) {
                          useSmallOnly = false;
                        }

                        if (cfg.smallOnly || (!hasLargeFlat && hasSmallFlat)) {
                          useSmallOnly = true;
                        }

                        const Fb = largeFlat?.metafields?.custom?.coverage || 0;
                        const Fs = smallFlat?.metafields?.custom?.coverage || 0;
                        const Cb = largeCorner?.metafields?.custom?.coverage || 0;
                        const Cs = smallCorner?.metafields?.custom?.coverage || 0;

                        const totalFlat = A * (1 + P / 100);
                        const totalCorner = B * (1 + P / 100);

                        let flatLarge = 0,
                            flatSmall = 0,
                            cornerLarge = 0,
                            cornerSmall = 0;

                        /* ---------- FLAT CALCULATION ---------- */
                        if (A > 0) {
                          if (!useSmallOnly && hasLargeFlat && Fb > 0) {
                            flatLarge = Math.floor(totalFlat / Fb);

                            if (flatLarge < 1) flatLarge = 1;

                            const remainFlat = totalFlat - flatLarge * Fb;

                            if (!cfg.largeOnly && Fs > 0 && remainFlat > 0) {
                              flatSmall = Math.ceil(remainFlat / Fs);
                            } else {
                              flatSmall = 0;
                            }
                          }

                          if (useSmallOnly && hasSmallFlat && Fs > 0) {
                            flatSmall = Math.ceil(totalFlat / Fs);
                            if (flatSmall < 1) flatSmall = 1;
                          }
                        }

                        /* ---------- CORNERS ---------- */
                        if (!cfg.noCorners) {
                          if (!useSmallOnly && Cb > 0) {
                            cornerLarge = Math.ceil(totalCorner / Cb);
                          }
                          if (useSmallOnly && Cs > 0) {
                            cornerSmall = Math.ceil(totalCorner / Cs);
                          }
                        }

                        /* ---------- SUBTOTAL ---------- */
                        const subtotalCents =
                          (flatLarge   * (largeFlat?.price || 0)) +
                          (flatSmall   * (smallFlat?.price || 0)) +
                          (cornerLarge * (largeCorner?.price || 0)) +
                          (cornerSmall * (smallCorner?.price || 0));

                        subtotalEl.innerHTML = `Subtotal: <b>${formatMoney(subtotalCents)}</b>`;

                        /* ---------- BOX BREAKDOWN ---------- */
                        let html = `<strong>Box Breakdown:</strong><br>`;

