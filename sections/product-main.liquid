                      <script>
                      document.addEventListener('DOMContentLoaded', function () {
                        const productVariants = JSON.parse(
                          document.getElementById('productVariants')?.textContent || '[]'
                        );

                        const sfInput   = document.getElementById('sf');
                        const lfInput   = document.getElementById('lf');
                        const overageEl = document.getElementById('overage');
                        const boxInfo   = document.getElementById('boxesInfo');
                        const pricesEl  = document.getElementById('csPrices');
                        const cfg       = window.boxesTypeConfig || {};

                        if (!productVariants.length || !pricesEl || !boxInfo) return;

                        const sfBlock = pricesEl.querySelector('.price-sf');
                        const lfBlock = pricesEl.querySelector('.price-lf');

                        const DISCOUNT_RATE = 0.15;

                        const moneyRound = n => '$' + n.toFixed(2);
                        const moneyFloor = n => '$' + (Math.round(n * 100) / 100).toFixed(2);

                        /* ---------- HELPERS ---------- */

                      function findVariant(type, size, color) {
                        return productVariants.find(v => {
                          const title = v.title.toLowerCase();

                          const isType = title.includes(type);
                          const isSize =
                            size === 'large box'
                              ? title.includes('large')
                              : title.includes('small');

                          const isColor = !color || v.option1?.toLowerCase() === color;

                          return isType && isSize && isColor;
                        });
                      }

                        function getCoverage(v) {
                          return Number(v?.metafields?.custom?.coverage || 0);
                        }

                        function getBoxCounts() {
                          let fl = parseInt(boxInfo.dataset.flatLarge || 0);
                          let fs = parseInt(boxInfo.dataset.flatSmall || 0);
                          let cl = parseInt(boxInfo.dataset.cornerLarge || 0);
                          let cs = parseInt(boxInfo.dataset.cornerSmall || 0);

                          if (!fl && !fs && !cl && !cs && boxInfo.innerText) {
                            const t = boxInfo.innerText.toLowerCase();
                            fl = parseInt((t.match(/flat:\s*(\d+)\s*large/) || [])[1] || 0);
                            fs = parseInt((t.match(/flat:\s*(\d+)\s*small/) || [])[1] || 0);
                            cl = parseInt((t.match(/corner:\s*(\d+)\s*large/) || [])[1] || 0);
                            cs = parseInt((t.match(/corner:\s*(\d+)\s*small/) || [])[1] || 0);
                          }

                          return { fl, fs, cl, cs };
                        }

                        /* ---------- MAIN PRICE UPDATE ---------- */

                        function updatePrices() {
                          pricesEl.style.display = 'none';
                          sfBlock.style.display = 'none';
                          lfBlock.style.display = 'none';

                          const sf = parseFloat(sfInput?.value) || 0;
                          const lf = parseFloat(lfInput?.value) || 0;

                          const { fl, fs, cl, cs } = getBoxCounts();

                          if ((sf <= 0 && lf <= 0) || (!fl && !fs && !cl && !cs)) return;

                          const currentVariantId =
                            document.getElementById('currentVariantId')?.value || null;

                          const selected =
                            productVariants.find(v => v.id == currentVariantId) || productVariants[0];

                          const color = selected?.option1?.toLowerCase() || '';

                          const flatLarge   = findVariant('flat', 'large box', color);
                          const flatSmall   = findVariant('flat', 'small box', color);
                          const cornerLarge = findVariant('corner', 'large box', color);
                          const cornerSmall = findVariant('corner', 'small box', color);

                          let sfShown = false;
                          let lfShown = false;

                          /* ---------- PRICE PER SQUARE FT (FIXED FOR LARGE ONLY) ---------- */
                          if (sf > 0 && (fl || fs)) {
                            let trade = 0;
                            let msrp  = 0;
                            let coverage = 0;

                            if (flatLarge && fl) {
                              trade    += fl * flatLarge.price;
                              msrp     += fl * (flatLarge.price / (1 - DISCOUNT_RATE));
                              coverage += fl * getCoverage(flatLarge);
                            }

                            if (flatSmall && fs) {
                              trade    += fs * flatSmall.price;
                              msrp     += fs * (flatSmall.price / (1 - DISCOUNT_RATE));
                              coverage += fs * getCoverage(flatSmall);
                            }

                            // 🔑 KEY FIX:
                            const effSF = sf * (1 + (parseFloat(overageEl?.value) || 0) / 100);
                            let divisor = coverage;

                            // Large box only → price per entered SF
                            if (cfg.largeOnly && effSF > 0) {
                              divisor = effSF;
                            }

                            if (divisor > 0) {
                              sfBlock.querySelector('del').textContent =
                                moneyRound((msrp / divisor) / 100);
                              sfBlock.querySelector('strong').textContent =
                                moneyFloor((trade / divisor) / 100);
                              sfBlock.style.display = 'block';
                              sfShown = true;
                            }
                          }

                          /* ---------- PRICE PER LINEAR FT ---------- */
                          if (!cfg.noCorners && lf > 0 && (cl || cs)) {
                            let trade = 0;
                            let msrp  = 0;
                            let coverage = 0;

                            if (cornerLarge && cl) {
                              trade    += cl * cornerLarge.price;
                              msrp     += cl * (cornerLarge.price / (1 - DISCOUNT_RATE));
                              coverage += cl * getCoverage(cornerLarge);
                            }

                            if (cornerSmall && cs) {
                              trade    += cs * cornerSmall.price;
                              msrp     += cs * (cornerSmall.price / (1 - DISCOUNT_RATE));
                              coverage += cs * getCoverage(cornerSmall);
                            }

                            if (coverage > 0) {
                              lfBlock.querySelector('del').textContent =
                                moneyRound((msrp / coverage) / 100);
                              lfBlock.querySelector('strong').textContent =
                                moneyFloor((trade / coverage) / 100);
                              lfBlock.style.display = 'block';
                              lfShown = true;
                            }
                          }

                          if (sfShown || lfShown) {
                            pricesEl.style.display = 'block';
                          }
                        }

                        /* ---------- EVENTS ---------- */

                        ['input', 'change'].forEach(evt => {
                          document.addEventListener(evt, e => {
                            if (['sf', 'lf', 'overage'].includes(e.target.id)) {
                              updatePrices();
                            }
                          });
                        });

                        const observer = new MutationObserver(updatePrices);
                        observer.observe(boxInfo, { attributes: true, childList: true, subtree: true });

                        updatePrices();
                      });
                      </script>          
                  
                  {% else %}

                    <!-- Calculator Logic -->
                    <script>
                    document.addEventListener('DOMContentLoaded', function () {
                      const productVariants = JSON.parse(
                        document.getElementById('productVariants')?.textContent || '[]'
                      );
                      const subtotalEl = document.querySelector('.subtotal');
                      const sfInput = document.getElementById('sf');
                      const lfInput = document.getElementById('lf');
                      const overSelect = document.getElementById('overage');
                      const allSmall = document.getElementById('cl1');
                      const boxInfo = document.getElementById('boxesInfo');

                      if (!productVariants.length) return;

                      const formatMoney = cents =>
                        window.Shopify?.formatMoney
                          ? Shopify.formatMoney(cents)
                          : '$' + (cents / 100).toFixed(2);

                      function resetOutput() {
                        boxInfo.innerHTML = '';
                        boxInfo.style.display = 'none';

                        boxInfo.dataset.flatLarge = 0;
                        boxInfo.dataset.flatSmall = 0;
                        boxInfo.dataset.cornerLarge = 0;
                        boxInfo.dataset.cornerSmall = 0;

                        subtotalEl.innerHTML = 'Subtotal: <b>$0.00</b>';
                      }

                      function calculateTotals() {
                        const A = parseFloat(sfInput.value) || 0;
                        const B = parseFloat(lfInput.value) || 0;
                        const P = Number(overSelect.value);
                        const useSmallOnly = allSmall.checked;

                        if (A <= 0 && B <= 0) {
                          resetOutput();
                          return;
                        }

                        const variants = productVariants.filter(v =>
                          v.title.toLowerCase().includes('flat') ||
                          v.title.toLowerCase().includes('corner')
                        );

                        const largeFlat   = variants.find(v => v.title.toLowerCase().includes('large box') && v.title.toLowerCase().includes('flat'));
                        const smallFlat   = variants.find(v => v.title.toLowerCase().includes('small box') && v.title.toLowerCase().includes('flat'));
                        const largeCorner = variants.find(v => v.title.toLowerCase().includes('large box') && v.title.toLowerCase().includes('corner'));
                        const smallCorner = variants.find(v => v.title.toLowerCase().includes('small box') && v.title.toLowerCase().includes('corner'));

                        if (!largeFlat || !smallFlat) {
                          resetOutput();
                          return;
                        }

                        const Fb = parseFloat(largeFlat.metafields?.custom?.coverage || 0);
                        const Fs = parseFloat(smallFlat.metafields?.custom?.coverage || 0);
                        const Cb = parseFloat(largeCorner?.metafields?.custom?.coverage || 0);
                        const Cs = parseFloat(smallCorner?.metafields?.custom?.coverage || 0);

                        const totalFlat   = A * (1 + P / 100);
                        const totalCorner = B * (1 + P / 100);

                        let flatLarge = 0, flatSmall = 0, cornerLarge = 0, cornerSmall = 0;

                        /* ---------- FLAT ---------- */
                        if (A > 0) {
                          if (useSmallOnly) {
                            if (Fs > 0) {
                              flatSmall = Math.ceil(totalFlat / Fs);

                              if (flatSmall < 1) flatSmall = 1;
                            }
                          } else {
                            if (Fb > 0) {
                              flatLarge = Math.floor(totalFlat / Fb);

                              if (flatLarge < 1) flatLarge = 1;

                              const remainFlat = totalFlat - flatLarge * Fb;
                              if (Fs > 0 && remainFlat > 0) {
                                flatSmall = Math.ceil(remainFlat / Fs);
                              }
                            }
                          }
                        } else {
                          flatLarge = 0;
                          flatSmall = 0;
                        }

                        /* ---------- CORNERS ---------- */
                        if (B > 0 && largeCorner && smallCorner) {
                          if (useSmallOnly) {
                            if (Cs > 0) cornerSmall = Math.ceil(totalCorner / Cs);
                          } else {
                            if (Cb > 0) {
                              cornerLarge = Math.floor(totalCorner / Cb);
                              const remainCorner = totalCorner - cornerLarge * Cb;
                              if (Cs > 0 && remainCorner > 0) {
                                cornerSmall = Math.ceil(remainCorner / Cs);
                              }
                            }
                          }
                        }

                        /* ---------- SUBTOTAL ---------- */
                        const subtotalCents =
                          flatLarge * (largeFlat.price || 0) +
                          flatSmall * (smallFlat.price || 0) +
                          cornerLarge * (largeCorner?.price || 0) +
                          cornerSmall * (smallCorner?.price || 0);

                        subtotalEl.innerHTML = `Subtotal: <b>${formatMoney(subtotalCents)}</b>`;

                        boxInfo.dataset.flatLarge = flatLarge;
                        boxInfo.dataset.flatSmall = flatSmall;
                        boxInfo.dataset.cornerLarge = cornerLarge;
                        boxInfo.dataset.cornerSmall = cornerSmall;

                        let html = `<strong>Box Breakdown:</strong><br>`;

                        if (flatLarge > 0 || flatSmall > 0) {
                          const flatParts = [];
                          if (flatLarge > 0) flatParts.push(`${flatLarge} large box`);
                          if (flatSmall > 0) flatParts.push(`${flatSmall} small box`);
                          html += `<span>Flat: ${flatParts.join(' & ')}</span><br>`;
                        }

                        if (B > 0 && (cornerLarge > 0 || cornerSmall > 0)) {
                          const cornerParts = [];
                          if (cornerLarge > 0) cornerParts.push(`${cornerLarge} large box`);
                          if (cornerSmall > 0) cornerParts.push(`${cornerSmall} small box`);
                          html += `<span>Corner: ${cornerParts.join(' & ')}</span>`;
                        }

                        boxInfo.innerHTML = `<div>${html}</div>`;
                        boxInfo.style.display = 'block';
                      }

                      [sfInput, lfInput, overSelect, allSmall].forEach(el =>
                        el && el.addEventListener('input', calculateTotals)
                      );

                      document.addEventListener('change', function (e) {
                        if (e.target.matches('.custom-checkbox input[name="color"]')) {
                          sfInput.value = '';
                          lfInput.value = '';
                          overSelect.selectedIndex = 0;
                          allSmall.checked = false;
                          resetOutput();
                        }
                      });

                      resetOutput();
                    });
                    </script>

