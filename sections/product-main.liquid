<script>

document.addEventListener("DOMContentLoaded", function () {
 
  document.querySelectorAll('a[href="#contact-to-order"]').forEach(link => {
    link.addEventListener('click', function (e) {
      e.preventDefault();
      const popup = document.querySelector('.trigger-popup');
      if (popup) popup.classList.add('show');
    });
  });

  document.addEventListener('click', function (e) {
    if (e.target.classList.contains('tp-close') || e.target.classList.contains('trigger-popup')) {
      document.querySelector('.trigger-popup')?.classList.remove('show');
    }
  });

});

document.addEventListener('DOMContentLoaded', function() {
  const forms = document.querySelectorAll('.only-order-sample, .order-sample-b2b');
  if (!forms.length) return;

  const productDataEl = document.getElementById('productVariants');
  if (!productDataEl) return;

  const productData = JSON.parse(productDataEl.textContent);
  const variantRadios = document.querySelectorAll('.custom-checkbox input[name="color"]');
  const productOptions = {{ product.options | json }};
  const colorIndex = productOptions.findIndex(opt => opt.toLowerCase() === 'color');

  function getColor(variant) {
    return (
      (variant[`option${colorIndex + 1}`] || variant.option1 || '')
        .trim()
        .toLowerCase()
    );
  }

  forms.forEach(sampleForm => {
    const sampleInput = sampleForm.querySelector('#sampleVariantId');
    if (!sampleInput) return;

    let currentVariantInput = sampleForm.querySelector('#currentVariantId');
    if (!currentVariantInput) {
      currentVariantInput = document.createElement('input');
      currentVariantInput.type = 'hidden';
      currentVariantInput.id = 'currentVariantId';
      currentVariantInput.value = {{ product.selected_or_first_available_variant.id }};
      sampleForm.appendChild(currentVariantInput);
    }

    function ensureCartBadge() {
      document.querySelectorAll('.cart-count-badge').forEach((badge, i) => {
        if (i > 0) badge.remove();
        else if (!badge.textContent || badge.textContent.includes('null') || badge.textContent.trim() === '') {
          badge.textContent = '0';
        }
      });
      const headerCart = document.querySelector('.shipment, .header-cart, .site-header__cart') || document.body;
      let badge = headerCart.querySelector('.cart-count-badge');
      if (!badge) {
        badge = document.createElement('span');
        badge.className = 'cart-count-badge';
        badge.textContent = '0';
        headerCart.appendChild(badge);
      }
      [...headerCart.childNodes].forEach(node => {
        if (node.nodeType === 3 && node.textContent.trim().toLowerCase().includes('null')) node.remove();
      });
      return badge;
    }

    function findSampleVariant(baseVariantId) {
      const baseVariant = productData.find(v => v.id == baseVariantId);
      if (!baseVariant) return null;
      const colorValue = getColor(baseVariant);

      return (
        productData.find(v => {
          const variantColor = getColor(v);
          return v.title.toLowerCase().includes('sample') && variantColor === colorValue;
        }) || null
      );
    }

    variantRadios.forEach(radio => {
      radio.addEventListener('change', function() {
        const selectedValue = this.value.trim().toLowerCase();
        const selectedVariant = productData.find(v => {
          const colorValue = getColor(v);
          return colorValue === selectedValue && !v.title.toLowerCase().includes('sample');
        });

        if (selectedVariant) {
          currentVariantInput.value = selectedVariant.id;

          const colorSpan = document.querySelector('.pr-single-meta span');
          if (colorSpan) colorSpan.textContent = selectedVariant.option1;

          const priceEl = document.querySelector('.product-price');
          if (priceEl && typeof Shopify.formatMoney !== 'undefined') {
            priceEl.textContent = Shopify.formatMoney(selectedVariant.price);
          }
        }
      });
    });

    sampleForm.addEventListener('submit', async function(e) {
      e.preventDefault();

      const currentVariantId = currentVariantInput.value;
      const sampleVariant = findSampleVariant(currentVariantId);

      if (!sampleVariant) {
        alert('Sample variant not available for this color.');
        return;
      }

      const formData = new FormData();
      formData.append('id', sampleVariant.id);
      formData.append('quantity', 1);

      ensureCartBadge();
      let cartContainer = document.querySelector('cart-container');
      if (!cartContainer) {
        cartContainer = document.createElement('cart-container');
        document.body.appendChild(cartContainer);
      }

      try {
        await cartContainer.add(formData);
        window.dispatchEvent(new Event('kt.cart.reloaded'));
      } catch (err) {
        console.error('Cart add failed:', err);
      }
    });
  });

  window.addEventListener('kt.cart.reloaded', () => {
    const badge = document.querySelector('.cart-count-badge') || ensureCartBadge();
    fetch('/cart.js')
      .then(res => res.json())
      .then(data => {
        badge.textContent = (data.item_count || 0).toString();
      })
      .catch(() => {
        badge.textContent = '0';
      });
  });

  function refreshCartBadge() {
    let badge = document.querySelector('.cart-count-badge');
    const headerCart = document.querySelector('.header-cart, .site-header__cart') || document.querySelector('.shipment');
    if (!badge) {
      badge = document.createElement('span');
      badge.className = 'cart-count-badge';
      badge.textContent = '0';
      headerCart?.appendChild(badge);
    }

    fetch('/cart.js')
      .then(r => r.json())
      .then(cart => {
        const count = cart.item_count || 0;
        badge.textContent = count.toString();
      })
      .catch(() => {
        badge.textContent = '0';
      });
  }

  refreshCartBadge();
});
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const sliderDiv = document.querySelector('.product-single-slider-div');
  const featuredImage = document.querySelector('.variant-featured-image');

  if (!sliderDiv || !featuredImage) return;

  sliderDiv.addEventListener('mouseenter', () => {
    sliderDiv.classList.add('act');
  });

  featuredImage.addEventListener('mouseenter', () => {
    sliderDiv.classList.remove('act');
  });
});

document.addEventListener('DOMContentLoaded', function() {
  const galleryWrapper = document.querySelector('.product-single-slider');
  const imageContainer = document.querySelector('.variant-featured-image');
  const wrapperContainer = document.querySelector('.product-single-slider-wrap');
  const variantRadios = document.querySelectorAll('.custom-checkbox input[name="color"]');
  const swrapperContainer = document.querySelector('.product-single-slider-div');

  
  if (!galleryWrapper || !imageContainer || !variantRadios.length) return;

  const productData = {{ product | json }};
  const videoData = JSON.parse(document.getElementById('variantVideos').textContent);

  function initCustomArrows($slider) {
    if (!$slider.length) return;

    $('.custom-cursor').remove();

    const slideCount = $slider.find('.slide').length;
    if (slideCount <= 1) {
      return; 
    }

    const $cursor = $(`
      <div class="custom-cursor" style="display:none;position:fixed;pointer-events:none;z-index:99;">
        <svg class="arrow-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" width="50" height="50">
          <path class="arrow-left" d="M41.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l160 160c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L109.3 256 246.6 118.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-160 160z" fill="#1C2120"/>
          <path class="arrow-right" d="M278.6 233.4c12.5 12.5 12.5 32.8 0 45.3l-160 160c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L210.7 256 73.4 118.6c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l160 160z" fill="#1C2120"/>
        </svg>
      </div>
    `);

    $('body').append($cursor);

    let direction = 'right';

    function updateDirection(e) {
      const offset = $slider.offset();
      const x = e.pageX - offset.left;
      const sliderWidth = $slider.width();
      const newDirection = x < sliderWidth / 2 ? 'left' : 'right';

      $cursor.find('.arrow-left').removeClass('active');
      $cursor.find('.arrow-right').removeClass('active');

      if (newDirection === 'left') {
        $cursor.find('.arrow-left').addClass('active');
      } else {
        $cursor.find('.arrow-right').addClass('active');
      }

      direction = newDirection;

      $cursor.css({
        left: e.pageX - 35 + 'px',
        top: e.pageY - 35 + 'px'
      });
    }

    $slider.on('mouseenter', function(e) {
      $cursor.fadeIn(150);
      updateDirection(e);
    });

    $slider.on('mousemove', function(e) {
      updateDirection(e);
    });

    $slider.on('mouseleave', function() {
      $cursor.fadeOut(150);
    });

    $slider.on('click', function() {
      if (direction === 'right') $slider.slick('slickNext');
      else $slider.slick('slickPrev');
    });
  }

  function rebuildGallery(variant) {
    if (!variant) return;

    if (typeof $ !== 'undefined' && $(galleryWrapper).hasClass('slick-initialized')) {
      $(galleryWrapper).slick('unslick');
    }

    galleryWrapper.innerHTML = '';
    imageContainer.innerHTML = '';

    if (variant.featured_image) {
      imageContainer.innerHTML = `
        <div class="image-box">
          <img src="${variant.featured_image.src}" alt="${variant.title}" loading="lazy">
        </div>`;
    }

    const variantVideos = videoData[variant.id];
    let slidesHTML = '';

    if (variantVideos && variantVideos.length) {
      variantVideos.forEach(video => {
        slidesHTML += `
          <div class="slide">
            <div class="image-box">
              <video class="product-video" autoplay loop muted playsinline preload="auto">
                <source src="${video.url}" type="video/mp4">
              </video>
            </div>
          </div>`;
      });
    }

    if (!slidesHTML.trim()) {
      swrapperContainer.classList.add('d-none');
      wrapperContainer.classList.remove('vact');
      galleryWrapper.innerHTML = '';
    } else {
      swrapperContainer.classList.remove('d-none');
      wrapperContainer.classList.add('vact');
      galleryWrapper.innerHTML = slidesHTML;

      $(galleryWrapper)
        .on('init', function() {
          requestAnimationFrame(() => {
            const firstVideo = $(galleryWrapper).find('.slick-current video').get(0);
            if (firstVideo) {
              firstVideo.muted = true;
              firstVideo.play().catch(() => {
                setTimeout(() => firstVideo.play(), 500);
              });
            }
          });
        })
        .on('afterChange', function(event, slick, currentSlide) {
          $(galleryWrapper).find('video').each(function() {
            this.pause();
          });

          const activeVideo = $(galleryWrapper)
            .find('.slick-slide[data-slick-index="' + currentSlide + '"] video')
            .get(0);
          if (activeVideo) {
            activeVideo.muted = true;
            activeVideo.play().catch(() => {
              setTimeout(() => activeVideo.play(), 500);
            });
          }
        })
        .slick({
          dots: false,
          arrows: false,
          infinite: true,
          speed: 300,
          slidesToShow: 1,
          slidesToScroll: 1,
          adaptiveHeight: true
        });

      initCustomArrows($(galleryWrapper));
    }

    const colorText = document.querySelector('.pr-single-meta span');
    if (colorText) colorText.textContent = variant.option1;
    
  }

  variantRadios.forEach(radio => {
    radio.addEventListener('change', function() {
      const selectedValue = this.value.trim().toLowerCase();
      const variant = productData.variants.find(v =>
        v.option1 && v.option1.trim().toLowerCase() === selectedValue
      );
      rebuildGallery(variant);
    });
  });

  const defaultVariant = productData.variants.find(
    v => v.id === {{ product.selected_or_first_available_variant.id }}
  );
  rebuildGallery(defaultVariant);
});

$(window).on("scroll", function () {
     AOS.init();
 });
</script>

<script>

document.addEventListener('DOMContentLoaded', function () {
  document.querySelectorAll('.download-image').forEach(btn => {
    btn.addEventListener('click', e => {
      e.preventDefault();

      // Always get the CURRENT active featured image
      const activeImg = document.querySelector('.variant-featured-image img');
      if (!activeImg) {
        console.warn('No active image found');
        return;
      }

      const url = activeImg.src;
      const fileName = url.split('/').pop().split('?')[0];

      // Force download
      const link = document.createElement('a');
      link.href = url;
      link.download = fileName;
      document.body.appendChild(link);
      link.click();
      link.remove();
    });
  });


  document.querySelectorAll('.share-image').forEach(btn => {
    btn.addEventListener('click', e => {
      e.preventDefault();
      const imageUrl = btn.dataset.img;
      const title = btn.dataset.title;
      if (navigator.share) {
        navigator.share({
          title: title,
          text: `Check out this product: ${title}`,
          url: imageUrl
        }).catch(err => console.log('Share canceled', err));
      } else {
        navigator.clipboard.writeText(imageUrl).then(() => {
          alert('Image link copied to clipboard!');
        });
      }
    });
  });
});

document.addEventListener('DOMContentLoaded', function () {
  const shareBtn = document.querySelector('.share-product');
  const popup = document.querySelector('.share-popup');
  const closeBtn = document.querySelector('.close-share');

  if (!shareBtn || !popup) return;

  const title = shareBtn.dataset.title || document.title;
  const url = shareBtn.dataset.url || window.location.href;

  const fb = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;
  const tw = `https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`;
  const pin = `https://pinterest.com/pin/create/button/?url=${encodeURIComponent(url)}&description=${encodeURIComponent(title)}`;

  const fbLink = popup.querySelector('.share-fb');
  const twLink = popup.querySelector('.share-x');
  const pinLink = popup.querySelector('.share-pin');
  const copyLink = popup.querySelector('.share-copy');

  fbLink.href = fb;
  twLink.href = tw;
  pinLink.href = pin;

  // Handle Share button click
  shareBtn.addEventListener('click', e => {
    e.preventDefault();

    if (navigator.share) {
      navigator.share({ title, url })
        .catch(err => console.log('Share canceled:', err));
    } else {
      popup.classList.add('active');
    }
  });

  // Close popup
  closeBtn.addEventListener('click', () => popup.classList.remove('active'));
  popup.addEventListener('click', e => {
    if (e.target === popup) popup.classList.remove('active');
  });

  // Copy link
  copyLink.addEventListener('click', e => {
    e.preventDefault();
    navigator.clipboard.writeText(url).then(() => {
      copyLink.classList.add('copied');
      copyLink.querySelector('img').style.opacity = '0.5';
      alert('Product link copied!');
    });
  });
});

</script>

<script>
function wrapFirstWord() {
  document.querySelectorAll('.trigger-content h6').forEach(h6 => {
    if (h6.dataset.done) return;

    const text = h6.innerHTML.trim();
    if (!text) return;

    const parts = text.split(' ');
    if (parts.length < 2) return;

    h6.innerHTML = `<span class="first-word">${parts.shift()}</span> ${parts.join(' ')}`;
    h6.dataset.done = "1";
  });
}

document.addEventListener('DOMContentLoaded', () => {
  wrapFirstWord();

  $('.product-slider')
    .on('init afterChange setPosition', function () {
      setTimeout(wrapFirstWord, 0);
    });
});
</script>

<script>
document.addEventListener('click', function (e) {
  const btn = e.target.closest('[data-line]');
  if (!btn) return;

  if (window.__cartBusy) {
    e.preventDefault();
    e.stopImmediatePropagation();
    return;
  }

  const line = parseInt(btn.dataset.line, 10);
  if (!line) {
    e.preventDefault();
    e.stopImmediatePropagation();
  }
});
</script>  

<script>
document.addEventListener("DOMContentLoaded", function () {

  // Color radio buttons
  const radios = Array.from(
    document.querySelectorAll('.custom-checkbox input[name="color"]')
  );

  // Hidden input that stores the active variant ID
  const variantIdInput = document.getElementById('currentVariantId');

  // Variant map: [{ id, option1 }]
  const variants = window.productVariants || [];

  if (!radios.length || !variantIdInput || !variants.length) return;

  const normalize = v => (v || '').trim().toLowerCase();

  /* ---------------------------------------------
     Helpers
  ----------------------------------------------*/

  // Get variant object by color (option1)
  function getVariantByColor(color) {
    return variants.find(v => normalize(v.option1) === normalize(color));
  }

  // Update URL to use color instead of variant ID
  function setColorInUrl(color) {
    const url = new URL(window.location.href);
    url.searchParams.delete('variant'); // Remove Shopify variant ID
    url.searchParams.set('color', color);
    window.history.replaceState({}, '', url.toString());
  }

  // Read color from URL (?color=...)
  function getColorFromUrl() {
    return new URLSearchParams(window.location.search).get('color');
  }

  // Select the corresponding radio and trigger existing listeners
  function selectColor(color) {
    const radio = radios.find(r => normalize(r.value) === normalize(color));
    if (!radio) return false;

    if (!radio.checked) radio.checked = true;
    radio.dispatchEvent(new Event('change', { bubbles: true }));
    return true;
  }

  /* ---------------------------------------------
     1) ALWAYS: listen for color changes
        → update variant ID + URL
  ----------------------------------------------*/
  radios.forEach(radio => {
    radio.addEventListener('change', function () {
      const variant = getVariantByColor(this.value);
      if (!variant) return;

      variantIdInput.value = variant.id;
      setColorInUrl(variant.option1);
    });
  });

  /* ---------------------------------------------
     2) INIT: prioritize ?color= from URL
        fallback to Shopify selected variant
  ----------------------------------------------*/
  let applied = false;

  const colorFromUrl = getColorFromUrl();
  if (colorFromUrl) {
    const decodedColor = decodeURIComponent(colorFromUrl);
    const variant = getVariantByColor(decodedColor);

    if (variant) {
      selectColor(variant.option1);
      variantIdInput.value = variant.id;
      setColorInUrl(variant.option1);
      applied = true;
    }
  }

  // Fallback to Shopify default selected variant
  if (!applied) {
    const initialColor =
      "{{ product.selected_or_first_available_variant.option1 | escape }}";

    const initialVariant = getVariantByColor(initialColor);

    if (initialVariant) {
      selectColor(initialVariant.option1);
      variantIdInput.value = initialVariant.id;
      setColorInUrl(initialVariant.option1);
    }
  }

});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const techBox     = document.getElementById("variant-technical-info");
  const specsTabBtn = document.getElementById("specs-tab");
  const specsTabLi  = specsTabBtn?.closest("li");

  const firstTabBtn = document.querySelector('#myTab button.nav-link'); // first tab

  if (!techBox || !window.variantTechnicalInfo) return;

  function activateFirstTab() {
    if (!firstTabBtn) return;

    const firstTarget = document.querySelector(firstTabBtn.dataset.bsTarget);

    document.querySelectorAll('#myTab .nav-link').forEach(btn => {
      btn.classList.remove('active');
      btn.setAttribute('aria-selected', 'false');
    });

    document.querySelectorAll('.tab-pane').forEach(pane => {
      pane.classList.remove('show', 'active');
    });

    firstTabBtn.classList.add('active');
    firstTabBtn.setAttribute('aria-selected', 'true');

    if (firstTarget) {
      firstTarget.classList.add('show', 'active');
    }
  }

  function updateTechnicalInfo(variantId) {
    const html = window.variantTechnicalInfo[variantId] || "";

    if (html.trim() !== "") {
      techBox.innerHTML = html;
      if (specsTabLi) specsTabLi.style.display = "";
    } else {

      if (specsTabBtn?.classList.contains("active")) {
        activateFirstTab();
      }

      techBox.innerHTML = "";
      if (specsTabLi) specsTabLi.style.display = "none";
    }
  }

  const variantInput = document.getElementById("currentVariantId");
  if (!variantInput) return;

  updateTechnicalInfo(variantInput.value);

  let lastValue = variantInput.value;

  const observer = new MutationObserver(() => {
    if (variantInput.value !== lastValue) {
      lastValue = variantInput.value;
      updateTechnicalInfo(lastValue);
    }
  });

  observer.observe(variantInput, {
    attributes: true,
    attributeFilter: ["value"]
  });

});
</script>


