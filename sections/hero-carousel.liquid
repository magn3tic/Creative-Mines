<!-- Hero Start -->
<section class="hero-area">
  <div class="hero-slider">
    {% for block in section.blocks %}
      <div class="slide">
        <div class="hero-img">
          {% if block.settings.use_video and block.settings.video != blank %}
            <video autoplay playsinline muted loop poster="{{ block.settings.image | img_url: 'master' }}">
              <source src="{{ block.settings.video }}" type="video/mp4">
            </video>
          {% elsif block.settings.image != blank %}
            <img src="{{ block.settings.image | img_url: 'master' }}" alt="Hero Image">
          {% endif %}
          <div class="hero-text">
            <div class="container-fluid">
              <div class="row align-items-end">
                <div class="col-sm-6 order-sm-1 order-2">
                  {% if block.settings.heading != blank %}
                    <h1 class="hero-heading">{{ block.settings.heading }}</h1>
                  {% endif %}
                </div>
                <div class="col-sm-6 order-sm-2 order-1">
                  {% if block.settings.subheading != blank %}
                    <div class="text-sm-end text-start">
                        <span class="d-block title">
                          {{ block.settings.subheading }}
                          {% if customer %}
                            {{ customer.first_name }}
                          {% endif %}
                        </span>                      
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="slider-progress-holder">
    <div class="container-fluid">
      <div class="slider-progress"><span></span></div>
    </div>
  </div>

  <div class="hero-bottom-action">
    <div class="container-fluid">
      <div class="row align-items-center">
        <div class="col-sm-8">
          {% if section.settings.bottom_text != blank %}
            <p>{{ section.settings.bottom_text }}</p>
          {% endif %}
        </div>
        <div class="col-sm-4">
          <div class="hero-arrows">
            <div class="hero-prev-arrow"><em class="fa-solid fa-chevron-left"></em></div>
            <div class="hero-next-arrow"><em class="fa-solid fa-chevron-right"></em></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- Hero End -->

{% schema %}
{
  "name": "Hero Slider",
  "tag": "section",
  "class": "hero-area",
  "settings": [
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom Text"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "checkbox",
          "id": "use_video",
          "label": "Use video instead of image",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "video",
          "label": "Video URL (MP4 or external)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Stone Perfected"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading / Welcome Text",
          "default": "Welcome, Brent"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Hero Slider",
      "category": "Hero",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}