<!-- Hero Start -->
{% for block in section.blocks %}
<style>
  {% if block.settings.heading_size_xlarge != blank %}
  @media(min-width: 1601px) {
    .slide-{{ block.id }} .hero-heading { font-size: {{ block.settings.heading_size_xlarge }}px !important; }
  }
  {% endif %}
  {% if block.settings.heading_size_desktop != blank %}
  @media(min-width: 1201px) and (max-width: 1600px) {
    .slide-{{ block.id }} .hero-heading { font-size: {{ block.settings.heading_size_desktop }}px !important; }
  }
  {% endif %}
  {% if block.settings.heading_size_laptop != blank %}
  @media(max-width: 1200px) {
    .slide-{{ block.id }} .hero-heading { font-size: {{ block.settings.heading_size_laptop }}px !important; }
  }
  {% endif %}
  {% if block.settings.heading_size_mobile != blank %}
  @media(max-width: 767px) {
    .slide-{{ block.id }} .hero-heading { font-size: {{ block.settings.heading_size_mobile }}px !important; }
  }
  {% endif %}
</style>
{% endfor %}
<section class="hero-area">
  <div class="hero-slider">
    {% for block in section.blocks %}
      <div class="slide slide-{{ block.id }}">
        <div class="overlay" style="opacity: {{ block.settings.opacity }};"></div>
        <div class="hero-img">
          {% if block.settings.use_video and block.settings.video != blank %}
            <video autoplay playsinline muted loop poster="{{ block.settings.image | img_url: 'master' }}">
              <source src="{{ block.settings.video }}" type="video/mp4">
            </video>
          {% elsif block.settings.image != blank %}
            <img src="{{ block.settings.image | img_url: 'master' }}" alt="Hero Image">
          {% endif %}
          <div class="hero-text">
            <div class="container-fluid">
              <div class="row align-items-end">
                <div class="col-sm-8 order-sm-1 order-2">
                  {% if block.settings.pre_heading != blank %}
                    <span class="hero-pre-heading" style="font-size: {{ block.settings.pre_heading_size }}px;">{{ block.settings.pre_heading }}</span>
                  {% endif %}
                  {% if block.settings.heading != blank %}
                    <h1 class="hero-heading">
                      {{ block.settings.heading }}
                    </h1>
                  {% endif %}
                  {% if block.settings.subtitle != blank %}
                    <p class="hero-subtitle" style="font-size: {{ block.settings.subtitle_size }}px;">{{ block.settings.subtitle }}</p>
                  {% endif %}

                  {% if block.settings.button_text != blank and block.settings.button_link != blank %}
                    <a href="{{ block.settings.button_link }}"
                      class="cta-btn btn_default mt-4">
                      {{ block.settings.button_text }}
                    </a>
                  {% endif %}

                </div>
                <div class="col-sm-4 order-sm-2 order-1">
                  {% if block.settings.subheading != blank %}
                    <div class="text-sm-end text-start">
                        <span class="d-block title">
                          {{ block.settings.subheading }}
                          {% if customer %}
                            {{ customer.first_name }}
                          {% endif %}
                        </span>                      
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="hero-bottom-action">
          <div class="container-fluid">
            <div class="row align-items-center">
              <div class="col-sm-8">
                {% if block.settings.bottom_text != blank %}
                  {% if block.settings.bottom_text_link == blank %}
                    <p>{{ block.settings.bottom_text }}</p>
                  {% else %}
                    <a href="{{ block.settings.bottom_text_link }}">{{ block.settings.bottom_text }} <svg width="17" height="14" viewBox="0 0 17 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15.75 6.77441L0.75 6.77441" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M9.7002 0.750011L15.7502 6.77401L9.7002 12.799" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
                  {% endif %}                  
                {% endif %}
              </div>

              <div class="col-sm-4">
                <div class="hero-arrows">
                  <div class="hero-prev-arrow"><em class="fa-solid fa-chevron-left"></em></div>
                  <div class="hero-next-arrow"><em class="fa-solid fa-chevron-right"></em></div>
                </div>
              </div>

            </div>
          </div>
        </div>

      </div>
    {% endfor %}
  </div>

  <div class="slider-progress-holder">
    <div class="container-fluid">
      <div class="slider-progress"><span></span></div>
    </div>
  </div>

</section>
<!-- Hero End -->

{% schema %}
{
  "name": "Hero Slider",
  "tag": "section",
  "class": "hero-area",
  "settings": [
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "checkbox",
          "id": "use_video",
          "label": "Use video instead of image",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "video",
          "label": "Video URL (MP4 or external)"
        },
        {
          "type": "text",
          "id": "pre_heading",
          "label": "Pre-Heading (above title)"
        },
        {
          "type": "text",
          "id": "pre_heading_size",
          "label": "Pre-Heading Font Size (px)",
          "default": "18"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Stone Perfected"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle (below title)"
        },
        {
          "type": "text",
          "id": "subtitle_size",
          "label": "Subtitle Font Size (px)",
          "default": "18"
        },
        {
          "type": "header",
          "content": "Heading Font Sizes"
        },
        {
          "type": "text",
          "id": "heading_size_xlarge",
          "label": "Large screen font size (px)",
          "info": "Screens > 1600px. Leave blank to use the default style."
        },
        {
          "type": "text",
          "id": "heading_size_desktop",
          "label": "Desktop font size (px)",
          "info": "Screens 1201px – 1600px. Leave blank to use the default style."
        },
        {
          "type": "text",
          "id": "heading_size_laptop",
          "label": "Laptop font size (px)",
          "info": "Screens \u2264 1200px. Leave blank to use the default style."
        },
        {
          "type": "text",
          "id": "heading_size_mobile",
          "label": "Mobile font size (px)",
          "info": "Screens \u2264 767px. Leave blank to use the default style."
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading / Welcome Text"
        },
        {
          "type": "text",
          "id": "bottom_text",
          "label": "Bottom Text"
        },     
        {
          "type": "url",
          "id": "bottom_text_link",
          "label": "Bottom Text Link"
        },           
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "range",
          "id": "opacity",
          "label": "Overlay Opacity",
          "min": 0,
          "max": 1,
          "step": 0.1,
          "default": 0.1
        }               
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Hero Slider",
      "category": "Hero",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}