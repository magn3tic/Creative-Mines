<section class="content-area" data-aos="fade-up">
  <div class="container">
    <div class="row">
      <div class="col-md-4 col-sm-5">
        <div>
          {% if section.settings.heading != blank %}
            <h2 class="h4">{{ section.settings.heading }}</h2>
          {% endif %}

          {% comment %}
          Collect all categories (from checkbox IDs)
          {% endcomment %}
          {% assign all_categories = "option1,option2,option3,option4,option5,option6,option7,option8,option9,option10" | split: "," %}

          {% if section.settings.show_dropdown %}
            <!-- Mobile Dropdown -->
            <div class="faq_filter d-md-none">
              <select id="faqCategoryFilter">
                <option value="All">All Topics</option>
                {% for cat in all_categories %}
                  <option value="{{ cat }}">
                    {% case cat %}
                      {% when "option1" %}Design Options
                      {% when "option2" %}Installation & Application
                      {% when "option3" %}Technical Specifications
                      {% when "option4" %}Product Details
                      {% when "option5" %}Product Performance
                      {% when "option6" %}Customization & Design Support
                      {% when "option7" %}Environmental Benefits
                      {% when "option8" %}How to Order
                      {% when "option9" %}Pricing
                      {% when "option10" %}Care & Maintenance
                    {% endcase %}
                  </option>
                {% endfor %}
              </select>
            </div>

            <!-- Desktop Tabs -->
            <div class="faq-category-tab d-none d-md-block">
              <ul id="faqCategoryTabs">
                <li><a href="javascript:;" data-category="All" class="active">All Topics</a></li>
                {% for cat in all_categories %}
                  <li>
                    <a href="javascript:;" data-category="{{ cat }}">
                      {% case cat %}
                        {% when "option1" %}Design Options
                        {% when "option2" %}Installation & Application
                        {% when "option3" %}Technical Specifications
                        {% when "option4" %}Product Details
                        {% when "option5" %}Product Performance
                        {% when "option6" %}Customization & Design Support
                        {% when "option7" %}Environmental Benefits
                        {% when "option8" %}How to Order
                        {% when "option9" %}Pricing
                        {% when "option10" %}Care & Maintenance
                      {% endcase %}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="col-md-8 col-sm-7">
        <div class="pr-accordion ps-lg-5" id="accordionExample">

          {% for block in section.blocks %}
            {% assign uid = block.id %}

            {% if block.type == 'faq_item' %}
              {% assign catlist = '' %}
              {% for i in (1..10) %}
                {% assign key = 'cat_option' | append: i %}
                {% if block.settings[key] %}
                  {% assign catlist = catlist | append: 'option' | append: i | append: ',' %}
                {% endif %}
              {% endfor %}

              <div class="accordion-item" data-category="{{ catlist | strip }}">
                <div class="accordion-header">
                  <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#{{ uid }}" aria-expanded="false" aria-controls="{{ uid }}">
                    {{ block.settings.question }}
                    <em class="fa-solid fa-chevron-down"></em>
                  </button>
                </div>
                <div id="{{ uid }}" class="accordion-collapse collapse" data-bs-parent="#accordionExample">
                  <div class="accordion-body">
                    {{ block.settings.answer }}
                    {% if block.settings.faqvideo != blank %}
                      <div class="faq-video mt-3">{{ block.settings.faqvideo }}</div>
                    {% endif %}
                  </div>
                </div>
              </div>

            {% elsif block.type == 'faq_itemtwo' %}
              {% for i in (1..10) %}
                {% assign q_key = 'question_' | append: i %}
                {% assign a_key = 'answer_' | append: i %}
                {% assign v_key = 'faqvideo_' | append: i %}
                {% assign q = block.settings[q_key] %}
                {% assign a = block.settings[a_key] %}
                {% assign v = block.settings[v_key] %}
                {% if q != blank %}
                  {% assign sub_id = uid | append: '-' | append: i %}
                  {% assign catlist = '' %}
                  {% for j in (1..10) %}
                    {% assign key = 'cat_option' | append: j | append: '_' | append: i %}
                    {% if block.settings[key] %}
                      {% assign catlist = catlist | append: 'option' | append: j | append: ',' %}
                    {% endif %}
                  {% endfor %}

                  <div class="accordion-item" data-category="{{ catlist | strip }}">
                    <div class="accordion-header">
                      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#{{ sub_id }}" aria-expanded="false" aria-controls="{{ sub_id }}">
                        {{ q }}
                        <em class="fa-solid fa-chevron-down"></em>
                      </button>
                    </div>
                    <div id="{{ sub_id }}" class="accordion-collapse collapse" data-bs-parent="#accordionExample">
                      <div class="accordion-body">
                        {{ a }}
                        {% if v != blank %}
                          <div class="faq-video mt-3">{{ v }}</div>
                        {% endif %}
                      </div>
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const filter = document.getElementById("faqCategoryFilter");
  const tabs = document.querySelectorAll("#faqCategoryTabs a");
  const items = document.querySelectorAll(".accordion-item");

  function filterFaq(selected) {
    items.forEach(item => {
      const categories = (item.getAttribute("data-category") || "").split(",");
      const visible = selected === "All" || categories.includes(selected);
      item.style.display = visible ? "block" : "none";
    });
  }

  if (filter) {
    filter.addEventListener("change", function () {
      filterFaq(this.value);
      tabs.forEach(tab => tab.classList.remove("active"));
      document.querySelector(`#faqCategoryTabs a[data-category="${this.value}"]`)?.classList.add("active");
    });
  }

  if (tabs.length) {
    tabs.forEach(tab => {
      tab.addEventListener("click", function () {
        tabs.forEach(t => t.classList.remove("active"));
        this.classList.add("active");
        filterFaq(this.dataset.category);
        if (filter) filter.value = this.dataset.category;
      });
    });
  }
});
</script>

