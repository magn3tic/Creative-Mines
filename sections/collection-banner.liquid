<!-- content start -->
<section class="explore-collection-area desktop d-none d-md-block">
  <div class="inner">
    {% if section.settings.image != blank %}
      <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.heading | escape }}" class="collection-bg">
    {% endif %}
    <div class="info">
      <div class="container-fluid">
        {% if section.settings.subheading != blank %}
          <p>{{ section.settings.subheading }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.button_1_text != blank and section.settings.button_1_link != blank %}
          <a href="{{ section.settings.button_1_link }}" class="cta-btn btn_default">
            {{ section.settings.button_1_text }}
          </a>
        {% endif %}
        {% if section.settings.button_2_text != blank and section.settings.button_2_link != blank %}
          <a href="{{ section.settings.button_2_link }}" class="cta-btn btn_border_white">
            {{ section.settings.button_2_text }} <em class="fa-solid fa-arrow-right"></em>
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<section class="explore-collection-area d-md-none">
  <div class="inner">
    {% if section.settings.image != blank %}
      <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.heading | escape }}" class="collection-bg">
    {% endif %}
    <div class="info">
      <div class="container-fluid">
        {% if section.settings.subheading != blank %}
          <p>{{ section.settings.subheading }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.button_1_text != blank and section.settings.button_1_link != blank %}
          <a href="{{ section.settings.button_1_link }}" class="cta-btn btn_default">
            {{ section.settings.button_1_text }}
          </a>
        {% endif %}
        {% if section.settings.button_2_text != blank and section.settings.button_2_link != blank %}
          <a href="{{ section.settings.button_2_link }}" class="cta-btn btn_border_white">
            {{ section.settings.button_2_text }} <em class="fa-solid fa-arrow-right"></em>
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>
<!-- content End -->

{% schema %}
{
  "name": "Collection Banner",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore Collections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Modern Farmhouse"
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Primary Button Text",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Secondary Button Text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Collection Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}