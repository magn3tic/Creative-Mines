<!-- Hero Slider Section -->
<section class="hero-area">
  <div class="hero-slider">
    {% for block in section.blocks %}
      <div class="slide">
        <div class="hero-img">
          {% if block.type == 'image_slide' and block.settings.image != blank %}
            <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.heading | escape }}">
          {% elsif block.type == 'video_slide' and block.settings.video_url != blank %}
            <video autoplay playsinline muted loop poster="{{ block.settings.poster | img_url: 'master' }}">
              <source src="{{ block.settings.video_url }}" type="video/mp4">
            </video>
          {% endif %}

          <div class="container-fluid">
            <div class="story-banner">
              {% if block.settings.heading != blank %}
                <h1 class="banner-heading text_white">{{ block.settings.heading }}</h1>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="slider-progress-holder">
    <div class="container-fluid">
      <div class="slider-progress">
        <span></span>
      </div>
    </div>
  </div>

  <div class="hero-bottom-action">
    <div class="container-fluid">
      <div class="row align-items-center">
        <div class="col-sm-8">
          {% if section.settings.bottom_text != blank %}
            <p>{{ section.settings.bottom_text }}</p>
          {% endif %}
        </div>
        <div class="col-sm-4">
          <div class="hero-arrows">
            <div class="hero-prev-arrow"><em class="fa-solid fa-chevron-left"></em></div>
            <div class="hero-next-arrow"><em class="fa-solid fa-chevron-right"></em></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Slider",
  "settings": [
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom Text",
      "default": "Meet the artisans who perfected stone veneer."
    }
  ],
  "blocks": [
    {
      "type": "image_slide",
      "name": "Image Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Our Story"
        }
      ]
    },
    {
      "type": "video_slide",
      "name": "Video Slide",
      "settings": [
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL (MP4)"
        },
        {
          "type": "image_picker",
          "id": "poster",
          "label": "Video Poster"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Our Story"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slider",
      "blocks": [
        {
          "type": "image_slide"
        },
        {
          "type": "video_slide"
        }
      ]
    }
  ]
}
{% endschema %}