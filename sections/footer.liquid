<footer class="footer-area">
  <div class="container-fluid">
    <div class="row align-items-center justify-content-between">
      <div class="col-lg-3">
        <div class="footer-left">
          <div class="footer-logo">
            {% if section.settings.footer_logo %}
              <a href="{{ routes.root_url }}">
                <img src="{{ section.settings.footer_logo | image_url }}" alt="footer logo">
              </a>
            {% endif %}
          </div>
          {% for block in section.blocks %}
            {% if block.type == 'social_links' %}
              <ul class="footer-social">
                {% if block.settings.social_instagram %}<li><a href="{{ block.settings.social_instagram }}"><img src="{{ 'instagram.webp' | asset_url }}" alt="icon"></a></li>{% endif %}
                {% if block.settings.social_facebook %}<li><a href="{{ block.settings.social_facebook }}"><img src="{{ 'facebook.webp' | asset_url }}" alt="icon"></a></li>{% endif %}
                {% if block.settings.social_youtube %}<li><a href="{{ block.settings.social_youtube }}"><img src="{{ 'youtube.webp' | asset_url }}" alt="icon"></a></li>{% endif %}
                {% if block.settings.social_pinterest %}<li><a href="{{ block.settings.social_pinterest }}"><img src="{{ 'pinterest.webp' | asset_url }}" alt="icon"></a></li>{% endif %}
                {% if block.settings.social_linkedin %}<li><a href="{{ block.settings.social_linkedin }}"><img src="{{ 'linkedin.webp' | asset_url }}" alt="icon"></a></li>{% endif %}
                {% if block.settings.social_extra %}<li><a href="{{ block.settings.social_extra }}"><img src="{{ 'extra.webp' | asset_url }}" alt="icon"></a></li>{% endif %}
              </ul>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <div class="col-lg-8">
        <div class="footer-right">
          <div class="row justify-content-between">
            <div class="col-lg-6 col-sm-6">
              <div class="row">
                <div class="col-6">
                  <div class="footer-links">
                    {% if section.settings.resources_heading != blank %}
                        <span class="d-block footer_title">{{ section.settings.resources_heading }}</span>
                    {% endif %}
                 
                    <ul>
                      {% for link in linklists[section.settings.resources_menu].links %}
                        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                      {% endfor %}
                    </ul>
                  </div>
                </div>
                <div class="col-6">
                  <div class="footer-links">
                    {% if section.settings.connect_heading != blank %}
                        <span class="d-block footer_title">{{ section.settings.connect_heading }}</span>
                    {% endif %}                    
                    <ul>
                      {% for link in linklists[section.settings.connect_menu].links %}
                        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                      {% endfor %}
                    </ul>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-lg-5 col-sm-6">
              {% for block in section.blocks %}
                {% if block.type == 'newsletter' %}
                  <div class="footer-newsletter">
                    {% if block.settings.newsletter_heading != blank %}
                      <span class="d-block footer_title">{{ block.settings.newsletter_heading }}</span>
                    {% endif %}
                    {% if block.settings.newsletter_text != blank %}
                      <p>{{ block.settings.newsletter_text }}</p>
                    {% endif %}
                    
                    {% form 'customer', class: 'newsletter-form' %}
                      <input type="hidden" name="contact[tags]" value="newsletter">
                      
                      {{ form.errors | default_errors }}
                      
                      {% if form.posted_successfully? %}
                        <p class="alert alert-success">
                          {{ 'general.newsletter.confirmation_text' | t }}
                        </p>
                      {% endif %}
                    
                      <label for="newsletter-email" hidden>Email</label>
                      <input 
                        type="email" 
                        name="contact[email]" 
                        placeholder="Email Address" 
                        id="newsletter-email" 
                        required>
                        
                      <input type="submit" value="Join">
                    {% endform %}
                  
                    {% if block.settings.payment_image %}
                      <div class="footer-payments">
                        <img src="{{ block.settings.payment_image | image_url }}" alt="Payments">
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
          <div class="footer-bottom">
            <div class="row align-items-center justify-content-between">
              <div class="col-lg-6">
                <div class="left">
                  {% for link in linklists[section.settings.policy_links].links %}
                    <a href="{{ link.url }}">{{ link.title }}</a>
                  {% endfor %}
                </div>
              </div>
              <div class="col-lg-5">
                <div class="right">
                  <div class="row align-items-center">
                    <div class="col-lg-6">
                      <a href="tel:{{ section.settings.phone_number | replace: '(', '' | replace: ')', '' | replace: ' ', '' | replace: '-', '' }}">{{ section.settings.phone_number }}</a>
                    </div>
                    <div class="col-lg-6">
                      <div class="text-lg-end text-center">
                        {% for block in section.blocks %}
                          {% if block.type == 'copyright' %}
                            <p>{{ block.settings.copyright_text }}</p>
                          {% endif %}
                        {% endfor %}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
var lastScrollTop = 0;
var body = document.body;
window.addEventListener("scroll",function(){
var scrollTop = window.pageYOffset || document
.documentElement.scrollTop;
if(scrollTop > lastScrollTop){
    body.classList.add("nav-down");
}
else{
    body.classList.remove("nav-down");
}
lastScrollTop = scrollTop;
});

(function($) {
  function initVideoToggle(context) {
    const $scope = context ? $(context) : $(document);

    $scope.find('.story-video-box .play-video')
      .off('click.videoToggle')
      .on('click.videoToggle', function() {
        const $box = $(this).closest('.story-video-box');
        const video = $box.find('video.story-video').get(0);
        if (!video) return;

        if (video.paused) {
          video.play();
          $box.addClass('is-playing');
        } else {
          video.pause();
          $box.removeClass('is-playing');
        }
      });
  }

  document.addEventListener('DOMContentLoaded', function() {
    initVideoToggle();
  });

  document.addEventListener('shopify:section:load', function(e) {
    initVideoToggle(e.target);
  });
})(jQuery);

document.addEventListener('DOMContentLoaded', function() {
  $('.sp-collapse span').on('click', function() {
    const $parent = $(this).closest('.sp-collapse');

    $parent.toggleClass('active');

    $parent.find('.top-actions').stop(true, true).slideToggle(300);

    $(this).find('svg').toggleClass('rotated');
  });
});

</script>

