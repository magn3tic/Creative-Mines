<section class="simple-header bg-white pb-4">
  <div class="container-fluid d-md-flex justify-content-between align-items-end">
    {% if section.settings.heading != blank %}
      <h2 class="shb-heading mb-md-0">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.button_text != blank %}
      <a 
        href="{{ section.settings.button_link }}" 
        class="cta-btn btn_default"
      >
        {{ section.settings.button_text }}
      </a>
    {% endif %}
  </div>
</section>


{% schema %}
{
  "name": "Simple Header",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Heading Goes Here"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Simple Header"
    }
  ]
}
{% endschema %}