{% comment %} Featured Projects Section {% endcomment %}

<section class="product-slider-area featured-project pb-0">
  <div class="container-fluid">
    <div class="featured-project-heading">
      <div class="row align-items-end">
        <div class="col-md-7">
          {% if section.settings.heading != blank %}
            <h2 class="h3 mb-0 text-md-start text-center">{{ section.settings.heading }}</h2>
          {% endif %}
        </div>
        <div class="col-md-5">
          {% if section.settings.cta_text != blank and section.settings.cta_link != blank %}
            <div class="text-md-end text-center">
              <a href="{{ section.settings.cta_link }}">
                <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/camera.webp" alt="icon">
                {{ section.settings.cta_text }}
              </a>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <div class="product-slider">
    {% for block in section.blocks %}
      <div class="slide">
        {% if block.settings.image != blank %}
          <div class="pr-slider-image style2">
            <img src="{{ block.settings.image | img_url: 'master' }}" alt="image">

            {% if 
              block.settings.architect != blank or
              block.settings.builder != blank or
              block.settings.interior_design != blank or
              block.settings.structural_engineer != blank or
              block.settings.design_studio != blank or
              block.settings.project_name != blank
            %}
              <div class="photo-credit">
                <div class="pc-wrapper">
                  <ul>
                    {% if block.settings.architect != blank %}
                      <li>Architect&nbsp;- {{ block.settings.architect }}</li>
                    {% endif %}
                    {% if block.settings.builder != blank %}
                      <li>Builder&nbsp;- {{ block.settings.builder }}</li>
                    {% endif %}
                    {% if block.settings.interior_design != blank %}
                      <li>Interior Design&nbsp;- {{ block.settings.interior_design }}</li>
                    {% endif %}
                    {% if block.settings.structural_engineer != blank %}
                      <li>Structural Engineer&nbsp;- {{ block.settings.structural_engineer }}</li>
                    {% endif %}
                  </ul>
                </div>
                <div class="d-flex align-items-center justify-content-center">
                  <p>
                    {% if block.settings.design_studio != blank %}
                      <span><strong>Design Studio:</strong> {{ block.settings.design_studio }}</span>
                    {% endif %}
                    {% if block.settings.project_name != blank %}
                      {% if block.settings.design_studio != blank %} | {% endif %}
                      <span><strong>Project:</strong> {{ block.settings.project_name }}</span>
                    {% endif %}
                  </p>
                  <em class="fa-solid fa-chevron-up"></em>
                </div>
              </div>
            {% endif %}            
          </div>
        {% endif %}

        <div class="featured-project-info">
          <div class="container-fluid">
            <div class="row">
              <div class="col-lg-6">
                <div class="text pe-lg-5">
                  {% if block.settings.description != blank %}<p>{{ block.settings.description }}</p>{% endif %}
                </div>
              </div>
              <div class="col-lg-6">
                <div class="right">
                  {% if block.settings.designer != blank %}
                    <div class="ft-items">
                      <span class="d-block title">DESIGNER</span>
                      <ul><li>{{ block.settings.designer }}</li></ul>
                    </div>
                  {% endif %}

                  {% if block.settings.location != blank %}
                    <div class="ft-items">
                      <span class="d-block title">LOCATION</span>
                      <ul><li>{{ block.settings.location }}</li></ul>
                    </div>
                  {% endif %}

                  {% assign selected_products = block.settings.products %}
                  {% if selected_products != blank %}
                    <div class="ft-items">
                      <span class="d-block title">PRODUCT</span>
                      <ul>
                        {% for product in selected_products %}
                          <li><a href="{{ product.url }}">{{ product.title }}</a></li>
                        {% endfor %}
                      </ul>
                    </div>
                  {% endif %}
                
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="pr-slider-action ft-alt">
    <div class="container-fluid">
      <div class="inner">
        <div class="pr-slider-progress-holder">
          <div class="slider-progress"><span></span></div>
        </div>
        <div class="pr-slider-arrows">
          <div class="pr-slider-prev-arrow"><em class="fa-solid fa-chevron-left"></em></div>
          <div class="pr-slider-next-arrow"><em class="fa-solid fa-chevron-right"></em></div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Projects",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Featured Projects"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    }    
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Project Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide Image"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Project Description"
        },
        {
          "type": "text",
          "id": "designer",
          "label": "Designer"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location"
        },
       {
          "type": "product_list",
          "id": "products",
          "label": "Select Products"
        },
        {
          "type": "header",
          "content": "Photo Credits"
        },
        {
          "type": "text",
          "id": "architect",
          "label": "Architect"
        },
        {
          "type": "text",
          "id": "builder",
          "label": "Builder"
        },
        {
          "type": "text",
          "id": "interior_design",
          "label": "Interior Design"
        },
        {
          "type": "text",
          "id": "structural_engineer",
          "label": "Structural Engineer"
        },
        {
          "type": "text",
          "id": "design_studio",
          "label": "Design Studio"
        },
        {
          "type": "text",
          "id": "project_name",
          "label": "Project Name"
        }        
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Projects"
    }
  ]
}
{% endschema %}