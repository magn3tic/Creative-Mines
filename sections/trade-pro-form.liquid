{% assign green_states = settings.geo_location_b2b | split: ',' %}
{% assign red_states = settings.geo_location_red | split: ',' %}

<section class="trade-program-section">
  <div class="container-fluid">
    <div class="row">

      <!-- Left Content -->
      <div class="col-lg-6">
        <div class="trade-left-content">
          <h1 id="trade-main-heading">{{ section.settings.heading }}</h1>
          <p id="trade-main-subheading">{{ section.settings.subheading }}</p>
        </div>
      </div>

      <!-- Right Form -->
      <div class="col-lg-6">
        <div class="trade-form-wrap">

          <!-- Step Indicators -->
          <div class="trade-steps">
            <div class="step active" id="step-indicator-1">
              <div class="step-circle">1</div>
              <span>Select Location</span>
            </div>
            <div class="step-line"></div>
            <div class="step" id="step-indicator-2">
              <div class="step-circle">2</div>
              <span>Trade Info</span>
            </div>
            <div class="step-line"></div>
            <div class="step" id="step-indicator-3">
              <div class="step-circle">3</div>
              <span>Submission</span>
            </div>
          </div>

          <!-- Step 1: Select State -->
          <div class="trade-step" id="trade-step-1">
            <div class="form-group">
              <label for="state_select">YOUR STATE</label>
              <select id="state_select">
                <option value="">Select State</option>
                {% for state in green_states %}
                  {% assign s = state | strip %}
                  {% if s != blank %}
                    <option value="{{ s }}" data-type="green">{{ s }}</option>
                  {% endif %}
                {% endfor %}
                {% for state in red_states %}
                  {% assign s = state | strip %}
                  {% if s != blank %}
                    <option value="{{ s }}" data-type="red">{{ s }}</option>
                  {% endif %}
                {% endfor %}
              </select>
              <p class="state-hint">We'll match you with the right trade experience for your region.</p>
            </div>
            <button class="cta-btn btn_default mt-4" id="step1-next" type="button">Next</button>
          </div>

          <!-- Step 2: Green State Form -->
          <div class="trade-step" id="trade-step-2-green" style="display:none;">
            <p class="step2-intro">Get exclusive trade pricing, samples, and direct ordering access.</p>
            <form id="b2b-signup-form-green">
              <input type="hidden" name="selected_state" id="green-selected-state">
              <ul class="row trade-form-fields">
                <li class="col-sm-6">
                  <label>FIRST NAME<small>*</small></label>
                  <input type="text" name="first_name" required>
                </li>
                <li class="col-sm-6">
                  <label>LAST NAME<small>*</small></label>
                  <input type="text" name="last_name" required>
                </li>
                <li class="col-sm-6">
                  <label>COMPANY NAME<small>*</small></label>
                  <input type="text" name="company" required>
                </li>
                <li class="col-sm-6">
                  <label>JOB TITLE<small>*</small></label>
                  <input type="text" name="job_title" required>
                </li>
                <li class="col-sm-6">
                  <label>EMAIL<small>*</small></label>
                  <input type="email" name="email" required>
                </li>
                <li class="col-sm-6">
                  <label>PHONE NUMBER<small>*</small></label>
                  <input type="tel" name="phone" placeholder="(800) 4537040" required>
                </li>
                <li class="col-sm-6">
                  <label>TAX ID / EIN</label>
                  <input type="text" name="tax_id">
                </li>
                <li class="col-sm-6">
                  <label>WHAT'S YOUR TRADE<small>*</small></label>
                  <select name="trade_type" required>
                    <option value="">Select</option>
                    <option value="Architect">Architect</option>
                    <option value="Interior Designer">Interior Designer</option>
                    <option value="Builder/Developer">Builder/Developer</option>
                    <option value="Contractor">Contractor</option>
                    <option value="Installer">Installer</option>
                  </select>
                </li>
              </ul>
              <div class="trade-form-action">
                <div class="concent cl-action">
                  <input type="checkbox" name="accepts_marketing" id="newsletter-green" checked>
                  <label for="newsletter-green">Subscribe to our newsletter</label>
                </div>
                <button type="submit" class="cta-btn btn_default" id="green-submit-btn">Join StudioMine</button>
              </div>
            </form>
          </div>

          <!-- Step 2: Red State Form -->
          <div class="trade-step" id="trade-step-2-red" style="display:none;">
            <p class="step2-intro">Free samples, design tools & direct access to your local Creative Mines rep</p>
            <p class="step2-sub">Ordering in your state goes through our preferred local distributors. Your area rep will reach out within 1–2 business days to get you set up.</p>
            <form id="b2b-signup-form-red">
              <input type="hidden" name="selected_state" id="red-selected-state">
              <ul class="row trade-form-fields">
                <li class="col-sm-6">
                  <label>FIRST NAME<small>*</small></label>
                  <input type="text" name="first_name" required>
                </li>
                <li class="col-sm-6">
                  <label>LAST NAME<small>*</small></label>
                  <input type="text" name="last_name" required>
                </li>
                <li class="col-sm-6">
                  <label>COMPANY NAME<small>*</small></label>
                  <input type="text" name="company" required>
                </li>
                <li class="col-sm-6">
                  <label>EMAIL<small>*</small></label>
                  <input type="email" name="email" required>
                </li>
                <li class="col-sm-12">
                  <label>PHONE NUMBER<small>*</small></label>
                  <input type="tel" name="phone" placeholder="(800) 4537040" required>
                </li>
              </ul>
              <div class="trade-form-action">
                <div class="concent cl-action">
                  <input type="checkbox" name="accepts_marketing" id="newsletter-red" checked>
                  <label for="newsletter-red">Subscribe to our newsletter</label>
                </div>
                <button type="submit" class="cta-btn btn_default" id="red-submit-btn">Join StudioMine</button>
              </div>
            </form>
          </div>

          <div class="trade-step" id="trade-step-3-green" style="display:none;"></div>

          <div class="trade-step" id="trade-step-3-red" style="display:none;"></div>

        </div>
      </div>
    </div>
  </div>
</section>

<!-- Step 3 Green Thank You (full width) -->
<div id="thankyou-green" style="display:none;">
  <section class="trade-thankyou-section green">
    <div class="container-fluid">
      <div class="row align-items-center">
        <div class="col-lg-6">
          <h2>Welcome <span id="green-first-name"></span><br>to StudioMine.</h2>
          <p>Please allow us 1-2 days to confirm your Trade Pro application. Once approved your account will have all Trade Pro benefits including online ordering.</p>
        </div>
        <div class="col-lg-6">
          <div class="thankyou-benefits">
            <ul>
              <li>✓ Free direct-ship samples — order online now</li>
              <li>✓ Access to design tools, 3D files & seamless textures</li>
              <li>✓ Direct connection to your local area rep</li>
              <li>✓ Preferred distributor partners in your region</li>
              <li>✓ Trade pricing unlocked for online ordering</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<!-- Step 3 Red Thank You (full width) -->
<div id="thankyou-red" style="display:none;">
  <section class="trade-thankyou-section red">
    <div class="container-fluid">
      <div class="row align-items-center">
        <div class="col-lg-6">
          <h2>Welcome <span id="red-first-name"></span><br>to StudioMine.</h2>
          <p>Your account is under review. You'll receive a confirmation email within 24 hours with your login and trade pricing access.</p>
        </div>
        <div class="col-lg-6">
          <div class="thankyou-benefits">
            <ul>
              <li>✓ Exclusive trade pricing</li>
              <li>✓ Complimentary samples</li>
              <li>✓ Direct online ordering</li>
              <li>✓ 3D files, textures & design tools</li>
              <li>✓ Dedicated account specialist</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {

  const step1 = document.getElementById('trade-step-1');
  const step2Green = document.getElementById('trade-step-2-green');
  const step2Red = document.getElementById('trade-step-2-red');
  const stateSelect = document.getElementById('state_select');

  const indicators = {
    1: document.getElementById('step-indicator-1'),
    2: document.getElementById('step-indicator-2'),
    3: document.getElementById('step-indicator-3'),
  };

  function setStep(num) {
    for (let i = 1; i <= 3; i++) {
      indicators[i].classList.remove('active', 'completed');
      if (i < num) indicators[i].classList.add('completed');
      if (i === num) indicators[i].classList.add('active');
    }
  }

  // Step 1 → Next
  document.getElementById('step1-next').addEventListener('click', function () {
    const selected = stateSelect.options[stateSelect.selectedIndex];
    if (!selected.value) {
      alert('Please select a state.');
      return;
    }

    const type = selected.getAttribute('data-type');
    const stateName = selected.value;

    step1.style.display = 'none';
    setStep(2);

    if (type === 'green') {
      document.getElementById('green-selected-state').value = stateName;
      step2Green.style.display = 'block';
    } else {
      document.getElementById('red-selected-state').value = stateName;
      step2Red.style.display = 'block';
    }
  });

  // Phone formatting
  document.querySelectorAll('input[type="tel"]').forEach(input => {
    input.addEventListener('input', function (e) {
      let value = e.target.value.replace(/\D/g, '');
      if (value.length > 3 && value.length <= 6)
        value = `(${value.slice(0, 3)}) ${value.slice(3)}`;
      else if (value.length > 6)
        value = `(${value.slice(0, 3)}) ${value.slice(3, 10)}`;
      e.target.value = value;
    });
  });

  // Green Form Submit
  document.getElementById('b2b-signup-form-green').addEventListener('submit', async function (e) {
    e.preventDefault();
    const btn = document.getElementById('green-submit-btn');
    btn.disabled = true;
    btn.textContent = 'Submitting...';

    const form = e.target;
    const data = Object.fromEntries(new FormData(form).entries());

    const payload = {
      first_name: data.first_name || '',
      last_name: data.last_name || '',
      email: data.email || '',
      phone: data.phone || '',
      company: data.company || '',
      job_title: data.job_title || '',
      tax_id: data.tax_id || '',
      trade_type: data.trade_type || '',
      selected_state: data.selected_state || '',
      state_type: 'green',
      accepts_marketing: !!data.accepts_marketing,
      password: Math.random().toString(36).slice(-10) + 'A1!',
      license_file: '',
      license_filename: '',
      tax_exempt_doc_file: '',
      tax_exempt_doc_filename: '',
    };

    try {
      const res = await fetch('https://b2b-api.dkumar-18studios.workers.dev', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const json = await res.json();

      if (res.ok && json.message === 'Processed') {
        step2Green.style.display = 'none';
        setStep(3);
        document.getElementById('green-first-name').textContent = data.first_name;
        document.getElementById('thankyou-green').style.display = 'block';
        document.querySelector('.trade-program-section').style.display = 'none';
      } else {
        alert('⚠️ ' + (json.error_message || json.error || 'Submission failed.'));
      }
    } catch (err) {
      alert('❌ Network error — please try again.');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Join StudioMine';
    }
  });

  // Red Form Submit
  document.getElementById('b2b-signup-form-red').addEventListener('submit', async function (e) {
    e.preventDefault();
    const btn = document.getElementById('red-submit-btn');
    btn.disabled = true;
    btn.textContent = 'Submitting...';

    const form = e.target;
    const data = Object.fromEntries(new FormData(form).entries());

    const payload = {
      first_name: data.first_name || '',
      last_name: data.last_name || '',
      email: data.email || '',
      phone: data.phone || '',
      company: data.company || '',
      job_title: '',
      tax_id: '',
      trade_type: '',
      selected_state: data.selected_state || '',
      state_type: 'red',
      accepts_marketing: !!data.accepts_marketing,
      password: Math.random().toString(36).slice(-10) + 'A1!',
      license_file: '',
      license_filename: '',
      tax_exempt_doc_file: '',
      tax_exempt_doc_filename: '',
    };

    try {
      const res = await fetch('https://b2b-api.dkumar-18studios.workers.dev', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const json = await res.json();

      if (res.ok && json.message === 'Processed') {
        step2Red.style.display = 'none';
        setStep(3);
        document.getElementById('red-first-name').textContent = data.first_name;
        document.getElementById('thankyou-red').style.display = 'block';
        document.querySelector('.trade-program-section').style.display = 'none';
      } else {
        alert('⚠️ ' + (json.error_message || json.error || 'Submission failed.'));
      }
    } catch (err) {
      alert('❌ Network error — please try again.');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Join StudioMine';
    }
  });

});
</script>

{% schema %}
{
  "name": "Trade Program Form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Creative Mines Trade Program"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Order free quick ship samples online, access new CAD design tools, connect directly with your local area Creative Mines rep and unlock discounted pricing."
    }
  ],
  "presets": [
    {
      "name": "Trade Program Form"
    }
  ]
}
{% endschema %}