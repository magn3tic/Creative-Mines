<section class="page-banner-area alt no-height">
  {% if section.settings.image != blank %}
    <img 
      src="{{ section.settings.image | img_url: '2000x' }}" 
      alt="{{ section.settings.heading | escape }}" 
      class="bg">
  {% endif %}
  <div class="banner-inner">
    <div class="container-fluid">
      <div class="row align-items-end">
        <div class="col-lg-9">
          {% if section.settings.heading != blank %}
            <h1 class="banner-heading alt">{{ section.settings.heading }}</h1>
            <p style="color:white;">Explore our inspiration gallery and discover how our products come to life in real projects. Click on any photograph to view the products used and see how they come together in each space.</p>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

<section class="content-area">
  <div class="container-fluid">
    <!-- Filter Menu -->
    <div class="blog-top-action">
      <div class="row align-items-center">
        <div class="col-lg-12">
          <div class="blog-action-btn alt">
            <h2 class="h4">Filter By:</h2>
            <div class="blog-mobile-menu">
              <ul id="inspiration-filters">
                <li><a href="javascript:;" data-filter="all" class="active">All</a></li>
                {% assign all_tags = "" %}
                {% for block in section.blocks %}
                  {% assign tags = block.settings.tags | split: ',' %}
                  {% for tag in tags %}
                    {% assign safe_tag = tag 
                      | downcase 
                      | strip 
                      | replace: ' ', '-' 
                      | replace: '&', 'and' 
                      | replace: '/', '-' 
                      | replace: ',', '' 
                      | replace: '_', '-' %}
                    {% unless all_tags contains safe_tag %}
                      <li>
                        <a href="javascript:;" data-filter="{{ safe_tag }}">{{ tag | strip }}</a>
                      </li>
                      {% assign all_tags = all_tags | append: safe_tag | append: ',' %}
                    {% endunless %}
                  {% endfor %}
                {% endfor %}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Inspiration Grid -->
  <div class="container">
    <div id="portfolio">
      {% for block in section.blocks %}
        {% assign tags = block.settings.tags | split: ',' %}
        {% assign safe_tags = '' %}

        {% for tag in tags %}
          {% assign safe_tag = tag 
            | downcase 
            | strip 
            | replace: ' ', '-' 
            | replace: '&', 'and' 
            | replace: '/', '-' 
            | replace: ',', '' 
            | replace: '_', '-' %}
          {% assign safe_tags = safe_tags | append: safe_tag | append: ' ' %}
        {% endfor %}

        <div class="tile {{ safe_tags }}">
          <div class="inspiration-box js-open-popup" data-target="pop{{ forloop.index }}">
            <img src="{{ block.settings.image | img_url: '800x' }}" alt="">
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

<!-- Popups (moved outside the row) -->
{% for block in section.blocks %}
  {% assign product = all_products[block.settings.product] %}
  <div class="c_popup js-custom-popup" data-popup="pop{{ forloop.index }}">
    <div class="inner js-custom-popup-holder">
      <div class="close js-close-popup">x Close</div>
      <div class="inner-body">
        <div class="row">
          <div class="col-lg-8 col-sm-7">
            <div class="leftside position-relative">
              <img src="{{ block.settings.imagepop | img_url: 'master' }}" alt="">

              {% if 
                block.settings.architect != blank or
                block.settings.builder != blank or
                block.settings.interior_design != blank or
                block.settings.structural_engineer != blank or
                block.settings.design_studio != blank or
                block.settings.project_name != blank
              %}
                <div class="photo-credit">
                  <div class="pc-wrapper">
                    <ul>
                      {% if block.settings.architect != blank %}
                        <li>Architect&nbsp;- {{ block.settings.architect }}</li>
                      {% endif %}
                      {% if block.settings.builder != blank %}
                        <li>Builder&nbsp;- {{ block.settings.builder }}</li>
                      {% endif %}
                      {% if block.settings.interior_design != blank %}
                        <li>Interior Design&nbsp;- {{ block.settings.interior_design }}</li>
                      {% endif %}
                      {% if block.settings.structural_engineer != blank %}
                        <li>Structural Engineer&nbsp;- {{ block.settings.structural_engineer }}</li>
                      {% endif %}
                    </ul>
                  </div>
                  <div class="d-flex align-items-center justify-content-center">
                    <p>
                      {% if block.settings.design_studio != blank %}
                        <span><strong>Design Studio:</strong> {{ block.settings.design_studio }}</span>
                      {% endif %}
                      {% if block.settings.project_name != blank %}
                        {% if block.settings.design_studio != blank %} | {% endif %}
                        <span><strong>Project:</strong> {{ block.settings.project_name }}</span>
                      {% endif %}
                    </p>
                    <em class="fa-solid fa-chevron-up"></em>
                  </div>
                </div>
              {% endif %}               
            </div>
          </div>
          <div class="col-lg-4 col-sm-5">
            <div class="rightside">
              <h2 class="title">{{ product.title }}</h2>
              <p>{{ product.description | strip_html }}</p>

              {% assign variant = nil %}
              {% if block.settings.variant_id != blank %}
                {% assign variant_id_number = block.settings.variant_id | plus: 0 %}
                {% assign variant = product.variants | where: 'id', variant_id_number | first %}
              {% endif %}

              <div class="pr-single-meta">
                {% if variant %}
                  <p><span>Color: {{ variant.option1 }}</span></p>
                  {% if variant.featured_image %}
                    <img src="{{ variant.featured_image | img_url: '100x' }}" alt="{{ variant.option1 }}">
                  {% endif %}
                {% else %}
                  {% assign first_variant = product.selected_or_first_available_variant %}
                  <p><span>Color: {{ first_variant.option1 }}</span></p>
                  {% if first_variant.featured_image %}
                    <img src="{{ first_variant.featured_image | img_url: '100x' }}" alt="{{ first_variant.option1 }}">
                  {% endif %}
                {% endif %}
              </div>

              <!--<div class="cs-prices d-none">
                  <div class="price-item">
                      <span class="d-block">Price Per Square Ft.</span>
                      <span class="d-block price"><del>$24.85</del> $17.85</span>
                  </div>
                  <div class="price-item">
                      <span class="d-block">Price Per Linear Ft.</span>
                      <span class="d-block price"><del>$16.28</del> $12.28</span>
                  </div>
              </div>

              <div class="cs-prices d-none">
                {% if product.compare_at_price > product.price %}
                  <div class="price-item">
                    <span class="d-block">Price</span>
                    <span class="d-block price"><del>{{ product.compare_at_price | money }}</del> {{ product.price | money }}</span>
                  </div>
                {% else %}
                  <div class="price-item">
                    <span class="d-block">Price</span>
                    <span class="d-block price">{{ product.price | money }}</span>
                  </div>
                {% endif %}
              </div>-->

              <div class="cs-actions">
                <div class="left">
                  <a href="javascript:void(0);" 
                    class="cta-btn btn_default order-sample-btn" 
                    data-product="{{ block.settings.product }}" 
                    data-variant="{{ block.settings.variant_id }}">
                    Order <span> A Free </span> Sample
                  </a>

                  <a href="{{ product.url }}?variant={{ block.settings.variant_id }} " class="cta-btn btn_default_border">Shop the Look</a>
                </div>
              </div>

              {% if section.settings.ctalink %}
              <a href="{{ section.settings.ctalink }}" class="mg-action">
                  {% if section.settings.ctaimage %}
                  <img src="{{ section.settings.ctaimage | img_url: '800x' }}" alt="{{ section.settings.ctaheading }}">
                  {% endif %}                                    
                  <div class="inner">
                      {% if section.settings.ctaheading %}
                      <span class="d-block title">{{ section.settings.ctaheading }}</span>
                      {% endif %}                                        
                  </div>
              </a>
              {% endif %}                 
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endfor %}

<script>
jQuery(document).ready(function($) {
  const $tiles = $('#portfolio .tile');

  $('#inspiration-filters a').on('click', function(e) {
    e.preventDefault();
    const filterValue = $(this).data('filter').toLowerCase();

    $('#inspiration-filters a').removeClass('active');
    $(this).addClass('active');

    if (filterValue === 'all') {
      $tiles.removeClass('hide');
    } else {
      $tiles.each(function() {
        const $tile = $(this);
        if ($tile.hasClass(filterValue)) {
          $tile.removeClass('hide');
        } else {
          $tile.addClass('hide');
        }
      });
    }
  });
});
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const buttons = document.querySelectorAll('.order-sample-btn');

  buttons.forEach(btn => {
    btn.addEventListener('click', async function(e) {
      e.preventDefault();
      const productHandle = this.dataset.product;
      const variantId = parseInt(this.dataset.variant);

      if (!productHandle || !variantId) {
        alert('Product or variant not configured.');
        return;
      }

      // Fetch product JSON from Shopify
      const res = await fetch(`/products/${productHandle}.js`);
      const product = await res.json();

      // Find variant color and matching sample variant
      const selectedVariant = product.variants.find(v => v.id === variantId);
      if (!selectedVariant) {
        alert('Variant not found.');
        return;
      }

      const colorName = selectedVariant.option1 ? selectedVariant.option1.toLowerCase() : '';

      const sampleVariant = product.variants.find(v =>
        v.title.toLowerCase().includes('sample') &&
        v.option1 &&
        v.option1.toLowerCase() === colorName
      );

      if (!sampleVariant) {
        alert('Sample variant not found for this color.');
        return;
      }

      // Add to cart
      const formData = new FormData();
      formData.append('id', sampleVariant.id);
      formData.append('quantity', 1);

      try {
        const cartContainer = document.querySelector('cart-container') || document.body.appendChild(document.createElement('cart-container'));
        if (cartContainer.add) {
          await cartContainer.add(formData);
        } else {
          await fetch('/cart/add.js', { method: 'POST', body: formData });
        }
        window.dispatchEvent(new Event('kt.cart.reloaded'));
      } catch (err) {
        console.error('Add to cart failed:', err);
        alert('Something went wrong adding the sample to cart.');
      }
    });
  });
});
</script>

