<script charset="utf-8" type="text/javascript" src="//js.hsforms.net/forms/embed/v2.js"></script>

<!-- Commercial Representative Map Section -->
<section class="content-area bg_dark-green">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-5">
        <div class="content-text text-white location-heading">
          {% if section.settings.heading != blank %}
            <h2 class="h3 heading text-white">{{ section.settings.heading }}</h2>
          {% endif %}
          {% if section.settings.subheading != blank %}
            <p>{{ section.settings.subheading }}</p>
          {% endif %}
        </div>
      </div>

      <div class="col-lg-7">
        <div class="commercial-location-box">
          {% if section.settings.map_image != blank %}
            <img src="{{ section.settings.map_image | img_url: 'master' }}" alt="{{ section.settings.heading | escape }}">
          {% endif %}

          {% for block in section.blocks %}
          {% if block.settings.liquid != blank %}
            <div class="trigger-tooltip {{ block.settings.position_class }}">
                <div class="trigger-pin">
                    <img src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/plus-minus.webp" alt="icon">
                </div>
            </div>
            <div class="trigger-popup">
                <div class="tp-inner">
                    <div class="tp-close">&times;</div>
                    {{ block.settings.liquid }}
                </div>
            </div>
          {% endif %}            
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {

  document.addEventListener('click', function(e) {

    // If clicking a trigger-pin
    const pin = e.target.closest('.trigger-pin');
    if (pin) {

      // Close all popups
      document.querySelectorAll('.trigger-popup').forEach(p => p.classList.remove('show'));
      document.querySelectorAll('.trigger-pin').forEach(p => p.classList.remove('act'));

      // Activate clicked pin
      pin.classList.add('act');

      // Show its popup (next sibling)
      const popup = pin.parentElement.nextElementSibling;
      if (popup && popup.classList.contains('trigger-popup')) {
        popup.classList.add('show');
      }

      return;
    }

    // Close button
    if (e.target.closest('.tp-close')) {
      document.querySelectorAll('.trigger-popup').forEach(p => p.classList.remove('show'));
      document.querySelectorAll('.trigger-pin').forEach(p => p.classList.remove('act'));
      return;
    }

  });

});
</script>


{% schema %}
{
  "name": "Commercial Map",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Connect with a Territory Commercial Representative"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Find each representative by territory"
    },
    {
      "type": "image_picker",
      "id": "map_image",
      "label": "Map Image"
    }
  ],
  "blocks": [
    {
      "type": "representative",
      "name": "Representative Pin",
      "settings": [
        { "type": "text", "id": "position_class", "label": "Position Class (e.g. location-post1)" },
        {
          "type": "liquid",
          "id": "liquid",
          "label": "Hubspot Form Code"
        }        
      ]
    }
  ],
  "presets": [
    { "name": "Commercial Map" }
  ]
}
{% endschema %}