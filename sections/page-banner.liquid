<section class="page-banner-area{% if section.settings.style != 'style-three' %} alt{% endif %}{% if section.settings.style == 'style-one' %} no-height{% endif %}">
  {% if section.settings.image != blank %}
    <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.heading | escape }}" class="bg">
  {% endif %}
  <div class="banner-inner">
    <div class="container-fluid">
      <div class="row align-items-end">
        <div class="col-lg-9">
          {% if section.settings.heading != blank %}
            <h1 class="banner-heading{% if section.settings.style != 'style-three' %} alt{% endif %}">{{ section.settings.heading }}</h1>
          {% endif %}
          {% if section.settings.style != 'style-one' and section.settings.text != blank %}
            <div class="banner-text">
              {{ section.settings.text }}
            </div>
          {% endif %}
          {% if section.settings.style == 'style-two' and section.settings.button_label != blank and section.settings.button_link != blank %}
            <a href="{{ section.settings.button_link }}" class="cta-btn btn_default">{{ section.settings.button_label }}</a>
          {% endif %}
        </div>
        {% if section.settings.style == 'style-three' and section.settings.button_label != blank and section.settings.button_link != blank %}
          <div class="col-lg-3">
            <div class="text-lg-end text-left">
              <a href="{{ section.settings.button_link }}" class="cta-btn btn_default">{{ section.settings.button_label }}</a>
            </div>
          </div>
        {% endif %}

        {% if section.settings.style == 'style-two' and section.settings.rbutton_label != blank and section.settings.rbutton_link != blank %}
        <a href="{{ section.settings.rbutton_link }}" class="d-flex already-a-member">{{ section.settings.rbutton_label }} <svg width="18" height="14" viewBox="0 0 18 14" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M1.61548 7.15393L16.3847 7.15393" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
<path d="M10.8462 12.6923L16.3847 7.1538L10.8462 1.61534" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</svg></a>
        {% endif %}        



      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Banner",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "style",
      "label": "Style",
      "default": "style-one",
      "options": [
        { "value": "style-one", "label": "Style One" },
        { "value": "style-two", "label": "Style Two" },
        { "value": "style-three", "label": "Style Three" }
      ]
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Banner Text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "rbutton_label",
      "label": "Button Label(Already a Member)"
    },
    {
      "type": "url",
      "id": "rbutton_link",
      "label": "Button Link"
    },
  ],
  "presets": [
    {
      "name": "Page Banner"
    }
  ]
}
{% endschema %}