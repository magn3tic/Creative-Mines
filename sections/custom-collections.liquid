{% if section.settings.heading != blank %}
<section class="content-area py_m_20 cc-collections">
  <div class="container-fluid">      
      <div class="text-center section-heading">
          <h2 class="h2">{{ section.settings.heading }}</h2>
      </div>
{% else %}
<section class="content-area py_m_20 pb-0">
  <div class="container-fluid">      
{% endif %}
    
    <div class="row">
      {% for block in section.blocks %}
        {% assign delay = forloop.index0 | times: 250 %}
        <div class="col-sm-4" data-aos="fade-up" data-aos-delay="{{ delay }}">
          <a href="{{ block.settings.link | default: '#' }}" class="box style1 text-center et-js-tilt">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.title | escape }}">
            {% endif %}
            <div class="info">
              <div>
                {% if block.settings.title != blank %}
                  <span class="d-block title">{{ block.settings.title }}</span>
                {% endif %}
                {% if block.settings.button_label != blank %}
                  <span class="cta-btn btn_default">{{ block.settings.button_label }}</span>
                {% endif %}
              </div>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Collections",
  "tag": "section",
  "class": "content-area",
  "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      }    
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Collection Title"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Explore"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom Collections",
      "category": "Collections",
      "blocks": [
        { "type": "collection_item" },
        { "type": "collection_item" },
        { "type": "collection_item" }
      ]
    }
  ]
}
{% endschema %}