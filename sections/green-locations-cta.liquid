{% schema %}
{
  "name": "Locations - CTA",
  "tag": "section",
  "class": "section-gl-cta",
  "settings": [],
  "blocks": [
    {
      "type": "hero",
      "name": "CTA",
      "settings": [
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "image_picker",
          "id": "bg_image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Tagline",
          "default": "Homeowners"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Building Your Dream Home?"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Browse, sample, and buy direct at full MSRP"
        },
        {
          "type": "textarea",
          "id": "bullets",
          "label": "Bullet Points (one per line)",
          "default": "Transparent Pricing\nFree Samples\nDirect Shipping"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Explore Products"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Locations - CTA",
      "blocks": [
        {
          "type": "hero",
          "settings": {
          }
        }
      ]
    }
  ]
}
{% endschema %}