<br>
<br>
<br>
<!-- Content End -->

{% schema %}
{
  "name": "Image with Credits",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "text",
      "id": "architect",
      "label": "Architect"
    },
    {
      "type": "text",
      "id": "builder",
      "label": "Builder"
    },
    {
      "type": "text",
      "id": "interior",
      "label": "Interior Designer"
    },
    {
      "type": "text",
      "id": "engineer",
      "label": "Structural Engineer"
    },
    {
      "type": "text",
      "id": "design_studio",
      "label": "Design Studio"
    },
    {
      "type": "text",
      "id": "project",
      "label": "Project"
    }
  ],
  "blocks": [
    {
      "type": "tooltip",
      "name": "Tooltip Pin",
      "settings": [
        {
          "type": "richtext",
          "id": "tooltipcontent",
          "label": "Content"
        },
        {
          "type": "range",
          "id": "pos_x",
          "label": "Position X (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "pos_y",
          "label": "Position Y (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        }
      ]
    }
  ],  
  "presets": [
    {
      "name": "Image with Credits",
      "category": "Media",
      "blocks": []
    }
  ]
}
{% endschema %}