{% for block in section.blocks %}
  {% if block.type == 'media_text' %}
    <section class="experience-area">
      <div class="container-fluid">
        <div class="row align-items-lg-center">
          <div class="col-sm-6 {% if block.settings.image_position == 'right' %}order-sm-2{% else %}order-sm-1{% endif %}">
            <div class="content-img" data-aos="zoom-in">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.heading | escape }}">
              {% endif %}
            </div>
          </div>
          <div class="col-sm-6 {% if block.settings.image_position == 'right' %}order-sm-1{% else %}order-sm-2{% endif %}">
            <div class="content-text px-xxl-5" data-aos="fade-right">
              {% if block.settings.heading != blank %}<h2 class="text_white h2">{{ block.settings.heading }}</h2>{% endif %}
              {% if block.settings.text != blank %}{{ block.settings.text }}{% endif %}

              {% if block.settings.show_icons %}
                <div class="content-icon-teaser">
                  <div class="row">
                    {% for i in (1..3) %}
                      {% capture icon_id %}icon_{{ i }}{% endcapture %}
                      {% capture label_id %}label_{{ i }}{% endcapture %}
                      {% assign icon = block.settings[icon_id] %}
                      {% assign label = block.settings[label_id] %}
                      {% if icon != blank or label != blank %}
                        <div class="col-4">
                          <div class="c-icon-teaser">
                            {% if icon != blank %}<img src="{{ icon | img_url: 'small' }}" alt="{{ label | escape }}">{% endif %}
                            {% if label != blank %}<span class="d-block title">{{ label }}</span>{% endif %}
                          </div>
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              {% endif %}

              {% if block.settings.button_text != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="cta-btn btn_default">{{ block.settings.button_text }}</a>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </section>

  {% elsif block.type == 'media_text_bg' %}
    <section class="image-content-area">
      {% if block.settings.image != blank %}<img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.heading | escape }}" data-aos="zoom-in" class="bg-image d-none d-lg-block">{% endif %}
      <div class="container-fluid">
        <div class="row">
          <div class="col-sm-6">
            {% if block.settings.image != blank %}
              <div class="content-img d-lg-none">
                <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.heading | escape }}">
              </div>
            {% endif %}
          </div>
          <div class="col-sm-6">
            <div class="content-text" data-aos="fade-left">
              {% if block.settings.heading != blank %}
                <h2 class="h3">{{ block.settings.heading | newline_to_br }}</h2>
              {% endif %}              
              {% if block.settings.text != blank %}{{ block.settings.text }}{% endif %}
              {% if block.settings.button_text != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="cta-btn btn_default">{{ block.settings.button_text }}</a>
              {% endif %}    
            </div>
          </div>
        </div>
      </div>
    </section>

    {% elsif block.type == 'media_text_bg_dark' %}
    {% if block.settings.style == 'style2' %}
        <section class="content-area relative">
            <img class="resources-video-shape" src="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/dark-shape-bg.webp?v=1752488007" data-aos="zoom-in" alt="image">
            <div class="container large resources-contact">
                <div class="row">
                    <div class="col-sm-6 col-lg-5">
                        <div class="content-text resources-contact" data-aos="fade-right">
                            {% if block.settings.heading != blank %}
                              <h2 class="heading h4 text_white">{{ block.settings.heading | newline_to_br }}</h2>
                            {% endif %}              
                            {% if block.settings.text != blank %}{{ block.settings.text }}{% endif %}
                            {% if block.settings.button_text != blank and block.settings.button_link != blank %}
                              <a href="{{ block.settings.button_link }}" class="cta-btn btn_default">{{ block.settings.button_text }}</a>
                            {% endif %}                                
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-7">
                        <div class="resources-contact-image  d-md-none">
                            <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.heading | escape }}">
                        </div>
                    </div>
                </div>
            </div>
            <img class="resources-contact-bg" src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.heading | escape }}">
        </section>      
    {% else %}
      <section class="image-content-area alt dark-shape-bg">
        {% if block.settings.image != blank %}<img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.heading | escape }}" data-aos="zoom-in" class="bg-image d-none d-lg-block">{% endif %}
        <div class="container-fluid">
          <div class="row">
            <div class="col-sm-6 order-md-1 order-2">
              {% if block.settings.image != blank %}
                <div class="content-img d-lg-none">
                  <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.heading | escape }}">
                </div>
              {% endif %}
            </div>
            <div class="col-sm-6 order-md-2 order1">
              <div class="content-text" data-aos="fade-left">
                {% if block.settings.heading != blank %}
                  <h2 class="h3 text_white">{{ block.settings.heading | newline_to_br }}</h2>
                {% endif %}              
                {% if block.settings.text != blank %}{{ block.settings.text }}{% endif %}
                {% if block.settings.button_text != blank and block.settings.button_link != blank %}
                  <a href="{{ block.settings.button_link }}" class="cta-btn btn_default mt-4">{{ block.settings.button_text }}</a>
                {% endif %}    
              </div>
            </div>
          </div>
        </div>
      </section>
    {% endif %}        
  
    {% elsif block.type == 'media_text_bg_dark2' %}
    <section class="image-content-area black-shape-bg">
      {% if block.settings.image != blank %}<img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.heading | escape }}" data-aos="zoom-in" class="bg-image right d-none d-lg-block">{% endif %}
      <div class="container-fluid">
        <div class="row">
          <div class="col-sm-6 order-sm-2 order-1">
            {% if block.settings.image != blank %}
              <div class="content-img d-lg-none">
                <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.heading | escape }}">
              </div>
            {% endif %}
          </div>
          <div class="col-sm-6 order-sm-1 order-2">
            <div class="content-text" data-aos="fade-left">
              {% if block.settings.heading != blank %}
                <h2 class="h3 text_white">{{ block.settings.heading | newline_to_br }}</h2>
              {% endif %}              
              {% if block.settings.text != blank %}{{ block.settings.text }}{% endif %}
              {% if block.settings.button_text != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="cta-btn btn_default">{{ block.settings.button_text }}</a>
              {% endif %}    
            </div>
          </div>
        </div>
      </div>
    </section>

    {% elsif block.type == 'media_text_bg_dark3' %}
    <section class="content-area green-shape-bg" id="patterns">
      <div class="container large">
        <div class="row">
          <div class="col-sm-5 order-sm-1 order-2">
            <div class="content-text text_white" data-aos="fade-right">
              {% if block.settings.heading != blank %}
                <h2 class="h3 text_white">{{ block.settings.heading | newline_to_br }}</h2>
              {% endif %}              
              {% if block.settings.text != blank %}{{ block.settings.text }}{% endif %}
              {% if block.settings.button_text != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="cta-btn btn_default">{{ block.settings.button_text }}</a>
              {% endif %}    
            </div>
          </div>
          <div class="col-sm-6 ms-auto order-sm-2 order-1">
            {% if block.settings.image != blank %}
              <div class="content-img mobile-device" data-aos="zoom-in">
                <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.heading | escape }}">
              </div>
            {% endif %}
          </div>          
        </div>
      </div>
    </section>    
      
  {% endif %}
{% endfor %}

