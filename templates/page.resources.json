        "faq_item_JCNGRg": {
          "type": "faq_item",
          "settings": {
            "question": "Can you assist with creating a mock-up board for my project?",
            "answer": "<p>Yes, for larger projects we can help coordinate a mock-up board in collaboration with the project’s mason to ensure the selected materials, grout techniques and colors align with your design vision.</p>",
