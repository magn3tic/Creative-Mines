    "faq_inWnGh": {
      "type": "faq",
      "blocks": {
        "faq_item_zrrCgq": {
          "type": "faq_item",
          "settings": {
            "question": "Are your products resistant to mold, mildew, or efflorescence?",
            "answer": "<p>Creative Mines stone and brick veneer products are designed to resist mold, mildew, and efflorescence. However, these issues can sometimes develop on adjacent materials, such as grout, which may come into contact with our veneer. Proper installation, drainage, and maintenance can help prevent these concerns and ensure the lasting beauty of your project.</p>",
            "faqvideo": "",
            "cat_option1": false,
            "cat_option2": false,
            "cat_option3": false,
            "cat_option4": false,
            "cat_option5": false,
