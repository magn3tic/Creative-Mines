          }
        },
        "faq_item_nMTX7D": {
          "type": "faq_item",
          "settings": {
            "question": "Can your products be pressure washed without causing damage?",
            "answer": "<p>No, we recommend against pressure washing our stone. Consult Creative Mines Customer Support if cleaning requires a method outside our care & maintenance recommendations. Please contact them directly at <a href=\"mailto:create@creativemines.us\">create@creativemines.us</a></p>",
            "faqvideo": "",
