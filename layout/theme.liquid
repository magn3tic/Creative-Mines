<!doctype html>
<html 
  lang="{{ request.locale.iso_code }}"
  class="{% if request.design_mode %}design-mode{% endif %}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_primary }}">

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>

  {%- unless settings.favicon == blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: '32', height: '32' }}">
  {%- endunless -%}

  <link rel="icon" type="image/png" href="https://cdn.shopify.com/s/files/1/0634/0139/4275/files/favicon.png">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {% render 'meta-tags' %}

  {{ content_for_header }}

  {% render 'styles-scripts' %}

  <link href="{{ 'vendors/fontawesome/css/all.min.css' | asset_url }}" rel="stylesheet">
  <link href="{{ 'vendors/bootstrap/css/bootstrap.min.css' | asset_url }}" rel="stylesheet">
  <link href="{{ 'vendors/slick/slick-theme.css' | asset_url }}" rel="stylesheet">
  <link href="{{ 'vendors/slick/slick.css' | asset_url }}" rel="stylesheet">
  <link href="{{ 'vendors/aos/css/aos.css' | asset_url }}" rel="stylesheet">
  <link href="{{ 'fonts/fonts.css' | asset_url }}" rel="stylesheet">
  <link href="{{ 'style.css' | asset_url }}" rel="stylesheet">

   <!-- RB2B Visitor Identification -->
    <script>!function(key) {if (window.reb2b) return;window.reb2b = {loaded: true};var s = document.createElement("script");s.async = true;s.src = "https://ddwl4m2hdecbv.cloudfront.net/b/" + key + "/" + key + ".js.gz";document.getElementsByTagName("script")[0].parentNode.insertBefore(s, document.getElementsByTagName("script")[0]);}("7N850H54LYN1");</script>
 
</head>

<body class="{{ request.page_type | prepend: 'page-type-' }}">
  <a class="visually-hidden-focusable" href="#main">
    {{ 'general.accessibility.skip_content' | t }}
  </a>
  
  <div id="header-group">
    {% sections 'header-group' %}
  </div>

  <main id="main">
    {{ content_for_layout }}
  </main>

  <div id="footer-group">
    {% sections 'footer-group' %}
  </div>

  {% liquid
    render 'offcanvas-cart'
    render 'offcanvas-search'
    render 'modal-localization'
    render 'rich-snippets'
  %}

{% if customer %}
  {% if customer.tags contains 'B2B Approved' or customer.tags contains 'B2B_Approved' %}
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        document.body.classList.add('valid-b2b');
      });
    </script>
  {% endif %}
{% endif %}

<script>
  window.greenStates = {{ settings.geo_location | default: '' | json }};
  window.greenStatesB2B = {{ settings.geo_location_b2b | default: '' | json }};

  window.userGeo = null;
  window.isGreenState = false;
  window.isGreenStateB2B = false;

  window.userGeoReady = fetch('https://geoapi.dkumar-18studios.workers.dev/')
    .then(r => r.json())
    .then(geo => {
      window.userGeo = geo;
      const region = (geo.region || '').trim();

      const greenListB2C = (window.greenStates || '')
        .split(',')
        .map(s => s.trim())
        .filter(Boolean);

      const greenListB2B = (window.greenStatesB2B || '')
        .split(',')
        .map(s => s.trim())
        .filter(Boolean);

      window.isGreenState    = greenListB2C.includes(region);
      window.isGreenStateB2B = greenListB2B.includes(region);

      document.body.classList.add(window.isGreenState ? 'is-green-state' : 'is-non-green-state');
      document.body.classList.add(window.isGreenStateB2B ? 'is-green-state-b2b' : 'is-non-green-state-b2b');

      document.querySelectorAll('[data-geo-show]').forEach(el => {
        const raw = el.dataset.geoShow.trim();
        const targets = raw === '' ? greenListB2C : raw.split(',').map(s => s.trim());
        if (!targets.includes(region)) {
          el.remove();
        } else {
          el.style.display = 'block'; 
        }
      });

      document.querySelectorAll('[data-geo-show-b2b]').forEach(el => {
        const raw = el.dataset.geoShowB2b.trim();
        const targets = raw === '' ? greenListB2B : raw.split(',').map(s => s.trim());
        if (!targets.includes(region)) {
          el.remove();
        } else {
          el.style.display = 'block'; 
        }
      });

      document.dispatchEvent(new CustomEvent('geoReady', { detail: geo }));
      return geo;
    })
    .catch(err => console.log('Geo failed:', err));
</script>

  
</body>
</html>
    