{% if cart.items != empty %}
  <div class="offcanvas-footer pt-5">
    {% if cart.cart_level_discount_applications.size > 0 %}
      <ul 
        class="cart-discounts list-unstyled fs-xs mb-3 text-center alert alert-primary py-2 px-2" 
        aria-label="{{ 'cart.applied_discounts' | t }}">
        {% for discount in cart.cart_level_discount_applications %}
          <li class="">
            {% render 'svg-icons', icon: 'tag', size: 12, class: 'me-1' %}
            {{ discount.title }}
            (-{{ discount.total_allocated_amount | money }})
          </li>
        {% endfor %}
      </ul>
    {%- endif -%}
    <p class="cart-subtotal fs-5 mb-4" role="status">
      <span class="opacity-70 me-2">
        {{ 'cart.subtotal' | t }}: 
      </span>
      <span>
        {% if cart.items_subtotal_price > cart.total_price %}
          <s class="opacity-70 me-2">
            {{ cart.items_subtotal_price | money }}
          </s>
        {% endif %}
        <b>
          {{ cart.total_price | money }}
        </b>
      </span>
    </p>
    <button 
      class="btn btn-checkout cta-btn btn_default w-100" 
      type="button"
      id="checkoutTriggerBtn"
      onclick="document.getElementById('checkoutTermsPopup').classList.add('active')">
      {% render 'svg-icons', icon: 'lock', size: 18, class: 'me-2' %}
      {{ 'cart.checkout' | t }}
    </button>
    <p class="small text-center mt-3 mb-n2 fst-italic">
      {{ 'cart.taxes_shipping_at_checkout_html' | t }}
    </p>
  </div>

<div id="checkoutTermsPopup" class="checkout-terms-overlay">
    <div class="checkout-terms-box">
      <button class="checkout-terms-close" onclick="document.getElementById('checkoutTermsPopup').classList.remove('active')">&times;</button>
      
      <h4>{{ settings.checkout_terms_title }}</h4>

      <div class="checkout-terms-content">
        {{ settings.checkout_terms_description }}
      </div>

      <div class="checkout-terms-actions">
        {% form 'cart', cart %}
          <button 
            class="btn btn-checkout cta-btn btn_default w-100" 
            name="checkout" 
            type="submit"
            onclick="this.classList.add('loading')">
            {% render 'svg-icons', icon: 'lock', size: 18, class: 'me-2' %}
            Proceed to Checkout
          </button>
        {% endform %}
      </div>
    </div>
  </div>

{% endif %}